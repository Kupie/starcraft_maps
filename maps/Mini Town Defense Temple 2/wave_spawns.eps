// wave_spawns.eps
// Row-driven Player 8 boss wave spawner.
//
// Replaces boss_attacks.eps. Spawn data lives in wave_spawns.csv /
// wave_spawns_veryhard.csv and is generated into wave_spawns_array.eps
// by generate_wave_spawns_array_eps.py.
//
// No gas/resources are used for wave progression.
// Flow:
//   1. Countdown reaches 0 while armed -> start next wave immediately.
//   2. Spawn each CSV row after that row's WaveDelayMS.
//   3. After each CreateUnit batch, issue one patrol order from Location 1 to Temple.
//   4. When all rows are spawned and P8 has no men left in _area, reset countdown to 210.
//
// VeryHard mode: when Switch("VeryHardDifficulty") is Set, all row/delay/count
// lookups use the vh-prefixed arrays from wave_spawns_array.eps instead.
import common_vars;
import wave_spawns_array;

var currentWave = 0;
var activeWave = 0;
var activeWaveRow = 0;
var activeWaveEnd = 0;
var waveDelay = 0;
var waitingForClear = 0;
var patrolTimer = 0;
var moveTimer = 0;
var roundArmed = 0;
var startupGrace = 0;
var whiteBuildOrdered = 0;
var setHitPointsTo = EUDVariable(100);

const waveStarted = EUDArray(wave_spawns_array.NUM_WAVES + 1);

function onPluginStart() {
	foreach(i : py_range(0, wave_spawns_array.NUM_WAVES + 1)) {
		waveStarted[i] = 0;
	}
	currentWave = 0;
	activeWave = 0;
	activeWaveRow = 0;
	activeWaveEnd = 0;
	waveDelay = 0;
	waitingForClear = 0;
	roundArmed = 1;
	startupGrace = 0;
	patrolTimer = 0;
	moveTimer = 0;
	common_vars.bossWaveActive = 0;
	common_vars.finalWaveReached = 0;
	SetCountdownTimer(SetTo, 255);
}

function orderP8WaveUnits() {
	Order("(any unit)", P8, "EnemyPatrolSpawn", Patrol, "Temple");
}

function startWave(waveNumber) {
	waveStarted[waveNumber] = 1;
	currentWave = waveNumber;
	common_vars.currentWave = waveNumber;
	activeWave = waveNumber;

	if (Switch("VeryHardDifficulty", Set)) {
		activeWaveRow = wave_spawns_array.vhWaveSpawnFirstRow[waveNumber];
		activeWaveEnd = activeWaveRow + wave_spawns_array.vhWaveSpawnRowCount[waveNumber];
		waveDelay     = wave_spawns_array.vhWaveSpawnDelayFrames[activeWaveRow];
	} else {
		activeWaveRow = wave_spawns_array.waveSpawnFirstRow[waveNumber];
		activeWaveEnd = activeWaveRow + wave_spawns_array.waveSpawnRowCount[waveNumber];
		waveDelay     = wave_spawns_array.waveSpawnDelayFrames[activeWaveRow];
	}

	waitingForClear = 1;
	roundArmed = 0;
	startupGrace = common_vars.waveStartupGraceInit;
	common_vars.bossWaveActive = 1;
	bwrite(0x58D3F7, 255);	// P8 Protoss Armor = 255 during boss wave

	if (waveNumber == wave_spawns_array.NUM_WAVES && common_vars.finalWaveReached == 0) {
		common_vars.finalWaveReached = 1;
		DisplayTextAll("\x13\x07Thanks For Playing!  You Won! Now survive for as long as you can on the endless bonus round! Goodluck!\r\n\x13\x06EUD Revamp by Kupie. Test version 1\r\n\x13\x062high - 2014\r\n\r\n\r\n\r\n\r\n");
	}
}

function finishWaveRows() {
	activeWave = 0;
	activeWaveRow = 0;
	activeWaveEnd = 0;
	waveDelay = 0;
	// Keep bossWaveActive set until spawned enemies are dead and the countdown is reset.
}

function resetCountdownForNextWave() {
	SetCountdownTimer(SetTo, 240);
	ModifyUnitHitPoints(1, "Buildings", P7, "Temple", 100);
	ModifyUnitShields(1, "Buildings", P7, "Temple", 100);
	ModifyUnitShields(All, "Warbringer (Reaver)", P7, "Anywhere", 100);
	ModifyUnitHitPoints(All, "Warbringer (Reaver)", P7, "Anywhere", 100);
	waitingForClear = 0;
	roundArmed = 1;
	common_vars.bossWaveActive = 0;
	bwrite(0x58D3F7, 135);	// P8 Protoss Armor = 135 during training phase
}

function initTownRebuild() {
	// ── Try to get CPU to rebuild town ────────────────────────────
	if (CountdownTimer(Exactly, 230) && (whiteBuildOrdered == 0)) {
		setcurpl(P7);
		SetResources(P7, SetTo, 9999999, OreAndGas);
		RunAIScriptAt("TSUP", "whitebuild1");
		RunAIScriptAt("TSUP", "whitebuild2");
		RunAIScriptAt("TSUP", "whitebuild3");
		RunAIScriptAt("TSUP", "whitebuild4");
		RunAIScriptAt("TSUP", "whitebuild5");
		RunAIScriptAt("TSUP", "whitebuild6");
		RunAIScriptAt("TSUP", "whitebuild7");
		RunAIScriptAt("TSUP", "whitebuild8");
		whiteBuildOrdered = 1;
	} else if (CountdownTimer(Exactly, 225)) {
		whiteBuildOrdered = 0;
	}
}

// Move units from staging area to patrol spawn, max once every ~5 seconds.
function moveSpawnedUnitsFromWaiting() {
	if (moveTimer >= 1) {
		moveTimer--;
	}
	if (moveTimer == 0) {
		if (Bring(P8, AtLeast, 1, "(any unit)", "Location 1")) {
			MoveUnit(All, "(men)", P8, "Location 1", "EnemyPatrolSpawn");
			Order("(any unit)", P8, "EnemyPatrolSpawn", Patrol, "Temple");
		}
		moveTimer = 30;	// every ~5 seconds at turbo speed
	}
}

function spawnCurrentRow() {
	if (activeWaveRow >= activeWaveEnd) {
		finishWaveRows();
		return;
	}

	var hpPercent = 100;
	if (common_vars.EasyModeEnable == 2) {
		hpPercent = common_vars.numPlayers * 100 / 5;
		if (hpPercent < 20)  { hpPercent = 20; }	// minimum 20%
		if (hpPercent > 100) { hpPercent = 100; }	// maximum 100%
	}

	foreach(unitIndex : py_range(0, wave_spawns_array.NUM_WAVE_UNITS)) {
		var count;
		if (Switch("VeryHardDifficulty", Set)) {
			count = wave_spawns_array.vhWaveSpawnCounts[activeWaveRow][unitIndex];
		} else {
			count = wave_spawns_array.waveSpawnCounts[activeWaveRow][unitIndex];
		}
		if (count > 0) {
			CreateUnit(count, wave_spawns_array.waveSpawnUnitIndex[unitIndex], "Location 1", P8);
			if (common_vars.EasyModeEnable == 2) {
				ModifyUnitHitPoints(All, "(men)", P8, "Location 1", hpPercent);
			}
		}
	}

	orderP8WaveUnits();

	activeWaveRow += 1;
	if (activeWaveRow >= activeWaveEnd) {
		if (activeWave == wave_spawns_array.NUM_WAVES) {
			// Endless bonus round: loop the final wave forever.
			if (Switch("VeryHardDifficulty", Set)) {
				waveDelay     = wave_spawns_array.vhWaveSpawnDelayFrames[activeWaveEnd - 1];
				activeWaveRow = wave_spawns_array.vhWaveSpawnFirstRow[activeWave];
			} else {
				waveDelay     = wave_spawns_array.waveSpawnDelayFrames[activeWaveEnd - 1];
				activeWaveRow = wave_spawns_array.waveSpawnFirstRow[activeWave];
			}
		} else {
			finishWaveRows();
		}
	} else {
		if (Switch("VeryHardDifficulty", Set)) {
			waveDelay = wave_spawns_array.vhWaveSpawnDelayFrames[activeWaveRow];
		} else {
			waveDelay = wave_spawns_array.waveSpawnDelayFrames[activeWaveRow];
		}
	}
}

function detectCountdownWaveStart() {
	if (
		roundArmed == 1 &&
		waitingForClear == 0 &&
		activeWave == 0 &&
		currentWave < wave_spawns_array.NUM_WAVES &&
		CountdownTimer(Exactly, 0)
	) {
		startWave(currentWave + 1);
	}
}

function tickActiveWave() {
	if (activeWave == 0) {
		return;
	}
	if (startupGrace > 0) {
		startupGrace -= 1;
		return;
	}
	if (waveDelay > 0) {
		waveDelay -= 1;
	} else {
		spawnCurrentRow();
	}
}

function detectWaveClearAndResetTimer() {
	if (
		waitingForClear == 1 &&
		activeWave == 0 &&
		CountdownTimer(Exactly, 0) &&
		Bring(P8, Exactly, 0, "(men)", "_area")
	) {
		resetCountdownForNextWave();
	}
}

// Force patrol every ~5 seconds in case units get stuck
function patrolEnemySpawn() {
	if (patrolTimer >= 1) {
		patrolTimer--;
	}
	if (patrolTimer == 0) {
		Order("(any unit)", P8, "EnemyPatrolSpawn", Patrol, "Temple");
		patrolTimer = 30;	// every ~5 seconds at turbo speed
	}
}

function afterTriggerExec() {
	const cp = getcurpl();

	detectCountdownWaveStart();
	tickActiveWave();
	detectWaveClearAndResetTimer();
	initTownRebuild();
	moveSpawnedUnitsFromWaiting();
	patrolEnemySpawn();

	setcurpl(cp);
}
