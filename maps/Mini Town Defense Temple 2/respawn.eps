// respawn.eps
// Per-player respawn queue — up to 20 simultaneous pending respawns per player.
// No Location 14 / Terran Civilian needed.
//
// Data layout (flat EUDArray, index = player * 20 + slot):
//   qTimer[player * 20 + slot] = frames remaining (0 = empty slot)
//
// Per-player state:
//   qHead[player]  = slot index of the next-to-expire timer
//   qCount[player] = how many slots are currently active
//
// Each death: penalty applied immediately, find first empty slot, set TOTAL_DELAY.
// Each frame: decrement all active slots. Slot hits 0 → spawn Civilian at _Heropick.
// eprint shows seconds remaining based on the soonest-expiring slot (qHead).
//
// RULE: save getcurpl() at top, restore at very bottom only.

import common_vars;

const SLOTS_PER_PLAYER = 20;
const NUM_PLAYERS      = 8;
const TOTAL_SLOTS      = 160;	// 8 * 20

// TOTAL_DELAY = penalty display time + respawn wait
// ~1.75s penalty display (42f) + ~3s respawn wait (72f) = ~4.75s total
const TOTAL_DELAY = 114;

const qTimer     = EUDArray(TOTAL_SLOTS);
const qHead      = EUDArray(NUM_PLAYERS);
const qCount     = EUDArray(NUM_PLAYERS);
const qCountLast = EUDArray(NUM_PLAYERS);

function onPluginStart() {
	const cp = getcurpl();

	foreach(i : py_range(TOTAL_SLOTS)) {
		qTimer[i] = 0;
	}
	foreach(i : py_range(NUM_PLAYERS)) {
		qHead[i]      = 0;
		qCount[i]     = 0;
		qCountLast[i] = 0;
	}

	setcurpl(cp);
}

// Scan player's slots and update qHead to the slot with the lowest non-zero timer.
function updateHead(player) {
	var base     = player * SLOTS_PER_PLAYER;
	var best     = 0xFFFFFFFF;
	var bestSlot = 0;
	foreach(s : py_range(SLOTS_PER_PLAYER)) {
		var t = qTimer[base + s];
		if (t >= 1 && t < best) {
			best     = t;
			bestSlot = s;
		}
	}
	qHead[player] = bestSlot;
}

function afterTriggerExec() {
	const cp = getcurpl();

	// ── Death detection ───────────────────────────────────────────────────
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		if (Deaths(player, AtLeast, 1, "(men)")) {
			SetDeaths(player, Subtract, 1, "(men)");

			// Penalty applied immediately on death
			SetScore(player, Subtract, 250, Custom);
			SetResources(player, Subtract, 50, Ore);
			setcurpl(player);
			eprintln("\x06You Have Died! -250 Experience. -50 Gold.");

			// Find first empty slot and queue this respawn
			var base = player * SLOTS_PER_PLAYER;
			foreach(s : py_range(SLOTS_PER_PLAYER)) {
				if (qTimer[base + s] == 0) {
					qTimer[base + s] = TOTAL_DELAY;
					qCount[player]++;
					updateHead(player);
					EUDBreak();
				}
			}
		}
	}

	// ── Tick all active slots ─────────────────────────────────────────────
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		var base = player * SLOTS_PER_PLAYER;

		foreach(s : py_range(SLOTS_PER_PLAYER)) {
			if (qTimer[base + s] >= 1) {
				qTimer[base + s]--;

				if (qTimer[base + s] == 0) {
					// Timer expired — send hero to pick screen
					CreateUnitWithProperties(1, "Terran Civilian", "_Heropick", player, UnitProperty(invincible = True));
					qCount[player]--;
					updateHead(player);
				}
			}
		}

		// ── eprint countdown (soonest expiring slot) ──────────────────────
		if (qCount[player] >= 1) {
			var headTimer = qTimer[player * SLOTS_PER_PLAYER + qHead[player]];

			// Ranges based on 24f per second. Condition fires every frame
			// so eprint refreshes itself before the ~75f display timeout.
			//if (headTimer >= 97) {
			//	setcurpl(player);
			//	eprintln("\x06You Have Died! -250 Experience. -50 Gold.");
			//}
			if (headTimer == 96) {
				setcurpl(player);
				eprintln("\x06Respawning in \x043\x06s...");
			}
			if (headTimer == 72) {
				setcurpl(player);
				eprintln("\x06Respawning in \x042\x06s...");
			}
			if (headTimer == 48) {
				setcurpl(player);
				eprintln("\x06Respawning in \x041\x06s...");
			}
			if (headTimer == 24) {
				setcurpl(player);
				eprintln("\x06Respawning...");
			}

			// Show the count only when it changes
			if (qCount[player] >= 1 && qCount[player] != qCountLast[player]) {
				qCountLast[player] = qCount[player];
				setcurpl(player);
				printAt(10, "\x13\x04({} respawns queued)", qCount[player]);
			}
		}
	}

	setcurpl(cp);
}
