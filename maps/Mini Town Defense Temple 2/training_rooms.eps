// training_rooms.eps
// Training room entry/exit, mob spawn per cell, despawn when empty.
//
// Only 3 CUWP property slots used:
//   prop_lurker  : 100% HP, burrowed (Lurkers)
//   prop_shield  : 100% HP, 100% shield (Dragoon, Archon)
//   All others   : plain CreateUnit (defaults to 100% HP, no properties needed)
//
// RULE: save getcurpl() at top, restore at very bottom only.

import common_vars;

const prop_lurker = UnitProperty(hitpoint = 100, burrowed = True);
const prop_shield = UnitProperty(hitpoint = 100, shield = 100);

const trainEntryLocs = list(
	py_str("Location 38"),
	py_str("Location 37"),
	py_str("Location 34"),
	py_str("Location 36"),
	py_str("Location 33"),
	py_str("Location 35")
);
const trainDestLocs = list(
	py_str("_Trainarchon"),
	py_str("_Traingoon"),
	py_str("_Trainhydra"),
	py_str("_Trainlurk"),
	py_str("_Trainultra"),
	py_str("_Trainzerg")
);
const trainMessages = list(
	"\x13\x05Good Luck, You Are Facing 5 Spirit Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
	"\x13\x05Good Luck, You Are Facing 5 Psionic Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
	"\x13\x05Good Luck, You Are Facing 5 Medium Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
	"\x13\x05Good Luck, You Are Facing 5 Stealth Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
	"\x13\x05Good Luck, You Are Facing 5 Mega Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
	"\x13\x05Good Luck, You Are Facing 5 Small Fiends.\r\n\r\n\r\n\r\n\r\n\r\n\r\n"
);

const exitLocs = list(
	py_str("Location 45"), py_str("Location 46"), py_str("Location 47"),
	py_str("Location 48"), py_str("Location 49"), py_str("Location 50"),
	py_str("Location 88")
);

const archonLocs = list(
	py_str("archon1"), py_str("archon2"), py_str("archon3"),
	py_str("archon4"), py_str("archon5"), py_str("archon6")
);
const dragonLocs = list(
	py_str("Dragoon1"), py_str("Dragoon2"), py_str("Dragoon3"), 
	py_str("Dragoon4"), py_str("Dragoon5"), py_str("Dragoon6"),
	py_str("Dragoon7"), py_str("Dragoon8"), py_str("Dragoon9"),
);
const hydraLocs = list(
	py_str("hydra1"), py_str("hydra2"), py_str("hydra3"),
	py_str("hydra4"), py_str("hydra5"), py_str("hydra6"),
	py_str("hydra7"), py_str("hydra8"), py_str("hydra9")
);
const ultraLocs = list(
	py_str("Ultralisk1"), py_str("Ultralisk2"), py_str("Ultralisk3"), 
	py_str("Ultralisk4"), py_str("Ultralisk5"), py_str("Ultralisk6")
);
const lurkerLocs = list(
	py_str("Lurker1"), py_str("Lurker2"), py_str("Lurker3"),
	py_str("Lurker4"), py_str("Lurker5"), py_str("Lurker6"),
	py_str("Lurker7"), py_str("Lurker8"), py_str("Lurker9")
);
const zerglingLocs = list(
	py_str("zergling1"), py_str("zergling2"), py_str("zergling3"), 
	py_str("zergling4"), py_str("zergling5"), py_str("zergling6")
);

const despawnLocs = list(
	py_str("despawn bastards 1"),
	py_str("despawn bastards 2"),
	py_str("despawn bastards 3")
);

function afterTriggerExec() {
	const cp = getcurpl();

	foreach(player : EUDLoopPlayer("Human", Force1)) {
		// ── Enter training selection area ─────────────────────────────────
		if (
			Bring(player, AtLeast, 1, "(men)", "to training") &&
			Bring(P8, Exactly, 0, "(men)", "_area")
		) {
			MoveUnit(All, "(men)", player, "to training", "Location 32");
			setcurpl(player);
			CenterView("_Trainingpick");
			DisplayText("\x13\x05Select A Monster To Train Against.\r\n\r\n\r\n\r\n\r\n\r\n\r\n");
		}

		// ── Select training room ──────────────────────────────────────────
		foreach(i : py_range(6)) {
			if (
				Bring(player, AtLeast, 1, "(men)", trainEntryLocs[i]) &&
				Bring(player, AtLeast, 1, "(men)", "_Trainingpick")
			) {
				MoveUnit(All, "(men)", player, trainEntryLocs[i], trainDestLocs[i]);
				setcurpl(player);
				CenterView(trainDestLocs[i]);
				DisplayText(trainMessages[i]);
			}
			if (
				Bring(player, AtLeast, 1, "(men)", trainEntryLocs[i]) &&
				Bring(player, Exactly, 0, "(men)", "_Trainingpick")
			) {
				MoveUnit(All, "(men)", player, trainEntryLocs[i], trainDestLocs[i]);
				setcurpl(player);
				CenterView(trainDestLocs[i]);
				DisplayText(trainMessages[i]);
			}
		}

		// ── Exit training room ─────────────────────────────────────────────
		foreach(i : py_range(7)) {
			if (Bring(player, AtLeast, 1, "(men)", exitLocs[i])) {
				MoveUnit(All, "(men)", player, exitLocs[i], "_healing");
				setcurpl(player);
				CenterView("_healing");
				DisplayText("\x13\x05You Have Exited The Training Center.\r\n\r\n\r\n\r\n\r\n\r\n\r\n");
			}
		}

		// ── Archon training mob spawn (100% HP + 100% shield) ─────────────
		foreach(i : py_range(6)) {
			if (
				Bring(player, AtLeast, 1, "(men)", archonLocs[i]) &&
				Bring(P8, Exactly, 0, "Protoss Archon", archonLocs[i])
			) {
				CreateUnitWithProperties(5, "Protoss Archon", archonLocs[i], P8, prop_shield);
				Order("(men)", P8, archonLocs[i], Patrol, archonLocs[i]);
			}
		}

		// ── Dragoon training mob spawn (100% HP + 100% shield) ────────────
		foreach(i : py_range(9)) {
			if (
				Bring(player, AtLeast, 1, "(men)", dragonLocs[i]) &&
				Bring(P8, Exactly, 0, "Protoss Dragoon", dragonLocs[i])
			) {
				CreateUnitWithProperties(5, "Protoss Dragoon", dragonLocs[i], P8, prop_shield);
			}
		}

		// ── Hydralisk training mob spawn (100% HP) ────────────────────────
		foreach(i : py_range(9)) {
			if (
				Bring(player, AtLeast, 1, "(men)", hydraLocs[i]) &&
				Bring(P8, Exactly, 0, "Zerg Hydralisk", hydraLocs[i])
			) {
				CreateUnit(5, "Zerg Hydralisk", hydraLocs[i], P8);
			}
		}

		// ── Ultralisk training mob spawn (100% HP) ────────────────────────
		foreach(i : py_range(6)) {
			if (
				Bring(player, AtLeast, 1, "(men)", ultraLocs[i]) &&
				Bring(P8, Exactly, 0, "Zerg Ultralisk", ultraLocs[i])
			) {
				CreateUnit(5, "Zerg Ultralisk", ultraLocs[i], P8);
				Order("(men)", P8, ultraLocs[i], Patrol, ultraLocs[i]);
			}
		}

		// ── Lurker training mob spawn (100% HP, burrowed) ─────────────────
		foreach(i : py_range(6)) {
			if (
				Bring(player, AtLeast, 1, "(men)", lurkerLocs[i]) &&
				Bring(P8, Exactly, 0, "Zerg Lurker", lurkerLocs[i])
			) {
				CreateUnitWithProperties(5, "Zerg Lurker", lurkerLocs[i], P8, prop_lurker);
			}
		}

		// ── Zergling training mob spawn (100% HP) ─────────────────────────
		foreach(i : py_range(6)) {
			if (
				Bring(player, AtLeast, 1, "(men)", zerglingLocs[i]) &&
				Bring(P8, Exactly, 0, "Zerg Zergling", zerglingLocs[i])
			) {
				CreateUnit(5, "Zerg Zergling", zerglingLocs[i], P8);
			}
		}
	}

	// ── Despawn orphan P8 mobs ────────────────────────────────────────────
	foreach(i : py_range(3)) {
		RemoveUnitAt(All, "(men)", despawnLocs[i], P8);
	}
	
	if (
		Bring(Force1,Exactly,0,"(men)","_Alltraining")
	) {
		RemoveUnitAt(All, "(men)", "_Alltraining", P8);
	}
	setcurpl(cp);
}
