import wave_spawns_indexes;
import WaveSpawnsFull;
import common_vars;

var roundsNotified = 0;

function notifyWave(round) {
	foreach(row : py_range(0, wave_spawns_indexes.WAVE_NOTIFY_ROWS)) {
		var strIdx = wave_spawns_indexes.waveNotifyStrings[round][row];
		if (strIdx != 0) {
			DisplayText(strIdx);
		}
	}
}		

function beforeTriggerExec() {
	if (roundsNotified < common_vars.currentRound) {
		printAll("notifying round {}, was notified {}", common_vars.currentRound, roundsNotified);
		roundsNotified = common_vars.currentRound;
		notifyWave(common_vars.currentRound - 1);
	}
}