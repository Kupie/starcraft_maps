import common_vars;

const tempInvul = EUDArray(7);
const permInvul = EUDArray(7);

function _rescueImpl(player, isPerm) {
	RemoveUnitAt(1, "Flag", "Start", player);
	CreateUnit(1, "Protoss Probe", "pSpawn", player);
	SetInvincibility(Enable, "Protoss Probe", player, "pSpawn");
	if (isPerm == 1) {
		permInvul[player] = 1;
		tempInvul[player] = 0;
	} else {
		tempInvul[player] = common_vars.tempInvulFrameAmount;
		permInvul[player] = 0;
	}
}

function onPluginStart() {
	foreach(i : py_range(7)) {
		tempInvul[i] = 0;
		permInvul[i] = 0;
	}
}

function afterTriggerExec() {
	if (!Switch("GameStarted", Set)) {
		return;
	}

	if (common_vars.currentRound < common_vars.roundPylonsBecomeVulnerable) {
		SetInvincibility(Enable, "Protoss Pylon", Force1, "playground");
	}
	if (common_vars.currentRound >= common_vars.roundPylonsBecomeVulnerable && Switch("pylon invuln", Set)) {
		SetSwitch("pylon invuln", Clear);
		DisplayTextAll("Pylons no longer invincible!");
		PlayWAVAll("staredit/wav/Industrial Alarm-SoundBible.com-1012301296.wav");
	}

	// ── Move probe to getprobe each frame ─────────────────────────
	MoveUnit(All, "Any unit", AllPlayers, "pSpawn", "getprobe");

	var savedCp = getcurpl();
	foreach(player : EUDLoopPlayer(None, Force1)) {
		setcurpl(player);

		// ── Force Alliance ──────────────────────────────────────────
		foreach(playerTarget : EUDLoopPlayer(None, Force1)) {
			SetAllianceStatus(playerTarget, Ally);
		}

		// ── Rescue detection ──────────────────────────────────────────
		if (
			Command(player, Exactly, 0, "Protoss Probe") &&
			Command(player, Exactly, 0, "Protoss Shield Battery") &&
			Command(player, Exactly, 1, "Flag") &&
			(
				Bring(Force1, AtLeast, 1, "Protoss Probe", "Start") ||
				Bring(Force1, AtLeast, 1, "Terran SCV", "Start")
			)
		) {
			if (Switch("Long Invulnerability", Cleared)) {
				_rescueImpl(player, 0);
				PlayWAV("sound/misc/transmission.wav");
				println("\x06- You have been saved -\x06\r\n\x04Temporary ({}s) Invincibility!\x04\r\n\r\n\x18+20 gas for everyone\x18\r\n", common_vars.tempInvulFrameAmount / 24);
			} else {
				_rescueImpl(player, 1);
				PlayWAV("sound/misc/transmission.wav");
				DisplayText("\x06- You have been saved -\x06\r\n\x04PERMANENT Invincibility!\x04\r\n\r\n\x18+20 gas for everyone\x18\r\n");
			}
			CenterView("getprobe");
			SetResources(Force1, Add, 20, Gas);
		}

		// ── Temp invul countdown ──────────────────────────────────────
		if (permInvul[player] == 0 && tempInvul[player] > 0) {
			tempInvul[player] -= 1;
			if (tempInvul[player] == 238) {
				PlayWAV("sound/misc/transmission.wav");
				DisplayText("\x06- Invincibility Wearing off in 10 seconds!");
			}
			if (tempInvul[player] == 0) {
				SetInvincibility(Disable, "Protoss Probe", player, "playground");
				PlayWAV("sound/misc/transmission.wav");
				DisplayText("\x06- Invincibility Wore Off!");
			}
		}
		if (permInvul[player] == 1) {
			SetInvincibility(Enable, "Protoss Probe", player, "playground");
		}
	}
	setcurpl(savedCp);
}