// unit_tracking.eps
// Handles: per-player location tracking (nexus/afterlife/Pylon), transporter
//          delivery, save-spot teleport, and P8 Scourge/IT stacking
import common_vars;

// P8 bb-mode spawn locations for Yggdrasill / Infested Terran mechanic (10 slots)
const bbModeLocs = list(
	py_str("bb mode"),  py_str("bb mode2"), py_str("bb mode3"),
	py_str("bb mode4"), py_str("bb mode5"), py_str("bb mode6"),
	py_str("bb mode7"), py_str("bb mode8"), py_str("bb mode9"),
	py_str("bb mode10"),
);

function afterTriggerExec() {
	var savedCp = getcurpl();
	// в”Ђв”Ђ Per-player location tracking в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
	// Classic: "Player N Always Preserve в†’ MoveLocation(CP, <unit>, Anywhere, <loc>)"
	// Tracks each mouse player's Gatewayв†’nexus, ShieldBatteryв†’afterlife, Probeв†’PylonN
	// MoveLocation(locationToMove, unit, player, sourceLocation) вЂ” no setcurpl needed
	foreach(i : py_range(7)) {
		MoveLocation(common_vars.nexusLocs[i],    "Protoss Gateway", common_vars.micePlayers[i],       "Anywhere");
		MoveLocation(common_vars.afterlifeLocs[i], "Protoss Shield Battery", common_vars.micePlayers[i], "Anywhere");
		MoveLocation(common_vars.pylonLocs[i],    "Protoss Probe", common_vars.micePlayers[i],          "Anywhere");
	}

	// Classic: "Player 8 Always Preserve в†’ MoveLocation(CP, Observer, Anywhere, spawn of sauron)"
	MoveLocation("spawn of sauron", "Protoss Observer", P8, "Anywhere");

	// Classic: "Player 8 Always Preserve Г— 10 в†’ MoveLocation(CP, Yggdrasill, Anywhere, bb modeN)"
	// All 10 bb mode locations track a Yggdrasill each frame
	foreach(i : py_range(10)) {
		MoveLocation(bbModeLocs[i], "Yggdrasill (Overlord)", P8, "Anywhere");
	}

	// в”Ђв”Ђ Transporter delivery в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
	// Classic: "Player N Bring(CP, any unit, transporter, >=1) Preserve в†’ MoveUnit to nexusN"
	// Purchased units created at "transporter" by shop.eps get moved to the player's home base
	foreach(i : py_range(7)) {
		if (Bring(common_vars.micePlayers[i], AtLeast, 1, "(any unit)", "transporter")) {
			MoveUnit(1, "(any unit)", common_vars.micePlayers[i], "transporter", common_vars.nexusLocs[i]);
		}
	}

	// в”Ђв”Ђ P8 Scourge stacking from Observers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
	// Classic: "Player 8 Command(CP,Observer,>=N) + Command(CP,Scourge,==0) Preserve в†’ CreateUnit(5,Scourge)"
	// With N observers and 0 scourge, ALL N triggers fire in one classic frame в†’ NГ—5 scourge created.
	// EPScript evaluates conditions sequentially, so we capture the zero-check BEFORE creating
	// anything so all iterations still fire correctly within the same beforeTriggerExec call.
	var scourgeIsZero = 0;
	if (Command(P8, Exactly, 0, "Zerg Scourge")) {
		scourgeIsZero = 1;
	}
	if (scourgeIsZero) {
		foreach(n : py_range(1, 11)) {
			// n is compile-time from py_range вЂ” valid as AtLeast count argument
			if (Command(P8, AtLeast, n, "Protoss Observer")) {
				CreateUnit(5, "Zerg Scourge", "spawn of sauron", P8);
			}
		}
	}

	// в”Ђв”Ђ P8 Infested Terran stacking from Yggdrasills в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
	// Classic: "Player 8 Command(CP,Yggdrasill,>=N) + Command(CP,IT,==0) Preserve в†’ CreateUnit(5,IT,bbModeN)"
	// Same pre-capture pattern as scourge above
	var itIsZero = 0;
	if (Command(P8, Exactly, 0, "Infested Terran")) {
		itIsZero = 1;
	}
	if (itIsZero) {
		foreach(n : py_range(1, 11)) {
			// n-1 is compile-time вЂ” bbModeLocs[n-1] is valid (indices 0..9)
			if (Command(P8, AtLeast, n, "Yggdrasill (Overlord)")) {
				CreateUnit(5, "Infested Terran", bbModeLocs[n - 1], P8);
			}
		}
	}
	
	setcurpl(savedCp);
}
