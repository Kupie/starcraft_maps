var beaconFlashTimer = 0;
var CurrentOwner = 8;

function beforeTriggerExec() {

	DoActions(
		// setInvincibility(allPlayers, $U("Protoss Probe"), everywhere, enable);
		// setMemory(0x00656f2c, setTo, 51711); //Set probe attack to max
	);
	// Set pauses to 200
	dwwrite(0x0058d718, 200);
	
	// Beacon flasher to make things more clear on minimap
	if (beaconFlashTimer == 0) {
		if (CurrentOwner != 8) {
			GiveUnits(All,"Terran Beacon",AllPlayers,"playground",P8);
		} else {
			GiveUnits(All,"Terran Beacon",AllPlayers,"playground",P11);
		}
		beaconFlashTimer = 48; // 36 frames
	}

}
