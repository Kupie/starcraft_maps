var hardRoll = 0;  // Set by wave_spawns.eps at step 1; read by wave_spawns_notifications.eps

const tempInvulFrameAmount = 1428;  // 23.81 frames per real-life second

var roundPylonsBecomeVulnerable = 70;  // Round where pylons stop being invincible

const micePlayers = list(P1, P2, P3, P4, P5, P6, P7);

const aiNudgeTimerSeconds = 3;  // How often (seconds) to nudge AI to attack

