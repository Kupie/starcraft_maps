import PluginVariables as msqcvar;

Trigger("Player 8"){
Conditions:
	Command("Player 11", "Kakaru (Twilight)", Exactly, 1);
	Command("Player 9", "Terran Civilian", Exactly, 1);
	Switch("ReduceSpawnsForNumPlayers", Not Set);

Actions:
	Comment("Full-spawn 1 civilian: 30xZerg Ultralisk, 20xTerran Firebat");
	Wait(3000);
	Kill Unit At Location("Mices - By \x006Hrufnarwa\x006", "Buildings", All, "spawner");
	Create Unit("Current Player", "Zerg Ultralisk", 30, "spawner");
	Wait(3000);
	Create Unit("Current Player", "Terran Firebat", 20, "spawner");
	Wait(1500);
	Set Switch("SpawnExtra", set);
}

	
	
	
}
