// Wave spawning system
// Step 0 (99→1): at countdown 8 — increment round, reset
// Step 1:        at countdown 7 — randomize locations, place beacons, reduce spawns
// Step 2:        at countdown 7→0 — beacon flash loop using frame counter
// Step 3:        at countdown 0 — kill buildings, kill beacons, start spawning
// Step 4:        normal spawning loop
// Step 5:        hard mode spawning loop
// Step 99:       idle

import wave_spawns_indexes;
import WaveSpawnsFull;
import WaveSpawnsSplit;
import HardModeSpawnsFull;
import common_vars;

var currentSpawnIndex  = 0;
var roundStep          = 99;
var spawnTimeCounter   = 0;
var hardRoll           = 0;
var s1left             = 0;
var s1top              = 0;
var s2left             = 0;
var s2top              = 0;
var beaconVisible      = 0;
var beaconFlashCounter = 0;


// ── Helper: check if spawner1 has any units this round ────────────────────────
function hasSpawner1Units(roundNumber) {
	foreach(i : py_range(0, wave_spawns_indexes.NUM_UNITS)) {
		if (WaveSpawnsFull.waveSpawnsFull1[roundNumber][i] > 0) {
			return 1;
		}
	}
	return 0;
}

// ── Helper: check if spawner2 has any units this round ────────────────────────
function hasSpawner2Units(roundNumber) {
	foreach(i : py_range(0, wave_spawns_indexes.NUM_UNITS)) {
		if (WaveSpawnsFull.waveSpawnsFull2[roundNumber][i] > 0) {
			return 1;
		}
	}
	return 0;
}

// ── Reduce spawns: multiply split counts by active player count ───────────────
function reduceSpawnsForNumPlayers(roundNumber) {
	var localPlayerCount = 0;
	foreach(player : EUDLoopPlayer()) {
		localPlayerCount += 1;
	}
	printAll("Number of Players: {}", localPlayerCount);
	foreach(i : py_range(0, wave_spawns_indexes.NUM_UNITS)) {
		WaveSpawnsFull.waveSpawnsFull1[roundNumber][i] = WaveSpawnsSplit.WaveSpawnsSplit1[roundNumber][i] * localPlayerCount;
		WaveSpawnsFull.waveSpawnsFull2[roundNumber][i] = WaveSpawnsSplit.WaveSpawnsSplit2[roundNumber][i] * localPlayerCount;

		if (wave_spawns_indexes.waveSpawnsUnitIndex[i] == $U("Protoss Observer") || wave_spawns_indexes.waveSpawnsUnitIndex[i] == $U("Yggdrasill (Overlord)")) {
			if (WaveSpawnsFull.waveSpawnsFull1[roundNumber][i] > 1) { WaveSpawnsFull.waveSpawnsFull1[roundNumber][i] = 1; }
			if (WaveSpawnsFull.waveSpawnsFull2[roundNumber][i] > 1) { WaveSpawnsFull.waveSpawnsFull2[roundNumber][i] = 1; }
		}
	}
}

const beaconOffsetX = [48,  48,  48,  48,  48,  112, 112, 208, 208, 272, 272, 272, 272, 272];
const beaconOffsetY = [32,  96,  160, 224, 288, 32,  288, 32,  288, 32,  96,  160, 224, 288];

function placeSpawnerBeacons(left, top) {
	foreach(i : py_range(14)) {
		setloc($L("BeaconPlacer"),
			left + beaconOffsetX[i],
			top  + beaconOffsetY[i],
			left + beaconOffsetX[i] + 1,
			top  + beaconOffsetY[i] + 1);
		CreateUnit(1, "Terran Beacon", "BeaconPlacer", P8);
	}
}

var beaconString = 0;
function onPluginStart() {
	beaconString = GetMapStringAddr($T("2 = Ban"));
}

function afterTriggerExec() {

	// ── Step 0: Increment round, reset ───────────────────────────────────────
	if (CountdownTimer(Exactly, 8) && roundStep == 99) {
		common_vars.currentRound += 1;
		if (common_vars.currentRound == 70) { SetSwitch($S("pylon invuln"), Clear); }
		currentSpawnIndex  = 0;
		beaconVisible      = 0;
		beaconFlashCounter = 0;
		roundStep = 1;
		printAll("Current Round: {}", common_vars.currentRound);
	}

	// ── Step 1: Randomize locations, place beacons, reduce spawns ────────────
	if (CountdownTimer(Exactly, 7) && roundStep == 1) {
		s1left   = f_rand() % 3776;
		s1top    = 160 + f_rand() % (3776 - 160);
		var s1right  = s1left + 320;
		var s1bottom = s1top  + 320;
		setloc($L("spawner"), s1left, s1top, s1right, s1bottom);

		s2left   = f_rand() % 3776;
		s2top    = 160 + f_rand() % (3776 - 160);
		var s2right  = s2left + 320;
		var s2bottom = s2top  + 320;
		setloc($L("spawner2"), s2left, s2top, s2right, s2bottom);

		if (Switch("ReduceSpawnsForNumPlayers", Set)) {
			reduceSpawnsForNumPlayers(common_vars.currentRound);
		}

		hardRoll = f_rand() % 4 + 1;
		dbstr_print(beaconString, "Enemy Spawn Warning\0");

		if (hasSpawner1Units(common_vars.currentRound)) {
			placeSpawnerBeacons(s1left, s1top);
			MinimapPing($L("spawner"));
		}
		if (hasSpawner2Units(common_vars.currentRound)) {
			placeSpawnerBeacons(s2left, s2top);
			MinimapPing($L("spawner2"));
		}
		beaconVisible      = 1;
		beaconFlashCounter = 24;
		roundStep = 2;
	}

	// ── Step 2: Beacon flash loop ─────────────────────────────────────────────
	if (roundStep == 2) {
		if (beaconFlashCounter == 0) {
			beaconFlashCounter = 24;  // flash every 1.5 seconds
			if (beaconVisible == 1) {
				if (hasSpawner1Units(common_vars.currentRound)) {
					KillUnitAt(All, "Terran Beacon", "spawner",  P8);
				//	MinimapPing($L("spawner"));
				}
				if (hasSpawner2Units(common_vars.currentRound)) {
					KillUnitAt(All, "Terran Beacon", "spawner2", P8);
				//	MinimapPing($L("spawner2"));
				}
				beaconVisible = 0;
			} else {
				if (hasSpawner1Units(common_vars.currentRound)) {
					placeSpawnerBeacons(s1left, s1top);
				//	MinimapPing($L("spawner"));
				}
				if (hasSpawner2Units(common_vars.currentRound)) {
					placeSpawnerBeacons(s2left, s2top);
				//	MinimapPing($L("spawner2"));
				}
				beaconVisible = 1;
			}
		}
		beaconFlashCounter--;
	}

	// ── Step 2 -> 3: Kill buildings, start spawning ────────────────────────────────
	if (CountdownTimer(Exactly, 0) && roundStep == 2) {
		if (hasSpawner1Units(common_vars.currentRound)) {
			KillUnitAt(All, "Terran Beacon", "spawner",  P8);
			KillUnitAt(All, "(buildings)",   "spawner",  Force1);
			MinimapPing($L("spawner"));
		}
		if (hasSpawner2Units(common_vars.currentRound)) {
			KillUnitAt(All, "Terran Beacon", "spawner2", P8);
			KillUnitAt(All, "(buildings)",   "spawner2", Force1);
			MinimapPing($L("spawner2"));
		}
		dbstr_print(beaconString, "2 = Ban\0");
		SetCountdownTimer(SetTo, 60);
		spawnTimeCounter = 16;
		roundStep = 3;
	}

	// ── Step 3: Normal spawning loop ──────────────────────────────────────────
	if (roundStep == 3 && spawnTimeCounter == 0) {
		var count  = WaveSpawnsFull.waveSpawnsFull1[common_vars.currentRound][currentSpawnIndex];
		var count2 = WaveSpawnsFull.waveSpawnsFull2[common_vars.currentRound][currentSpawnIndex];

		if (count == 0 && count2 == 0 && currentSpawnIndex < wave_spawns_indexes.NUM_UNITS) {
			currentSpawnIndex += 1;
		}

		var spawnIdx = currentSpawnIndex;

		if (count > 0 || count2 > 0) {
			if (count > 0) {
				CreateUnitWithProperties(count, wave_spawns_indexes.waveSpawnsUnitIndex[spawnIdx], "spawner", P8, UnitProperty(
					hitpoint = 100, shield = 100, energy = 100, hanger = 8, resource = 0,
					cloaked = False, burrowed = False, intransit = False, hallucinated = False, invincible = False)
				);
				WaveSpawnsFull.waveSpawnsFull1[common_vars.currentRound][currentSpawnIndex] = 0;
			}
			if (count2 > 0) {
				CreateUnitWithProperties(count2, wave_spawns_indexes.waveSpawnsUnitIndex[spawnIdx], "spawner2", P8, UnitProperty(
					hitpoint = 100, shield = 100, energy = 100, hanger = 8, resource = 0,
					cloaked = False, burrowed = False, intransit = False, hallucinated = False, invincible = False)
				);
				WaveSpawnsFull.waveSpawnsFull2[common_vars.currentRound][currentSpawnIndex] = 0;
			}
			currentSpawnIndex += 1;
			spawnTimeCounter = common_vars.delayBetweenSpawns;
		}
	}

	if (roundStep == 3 && spawnTimeCounter > 0) {
		spawnTimeCounter--;
	}

	if (roundStep == 3 && currentSpawnIndex >= wave_spawns_indexes.NUM_UNITS) {
		if (Switch("HardModeEnabled", Set)) {
			currentSpawnIndex = 0;
			spawnTimeCounter  = 0;
			roundStep = 4;
		} else {
			roundStep = 99;
		}
	}

	// ── Step 4: Hard mode spawning loop ──────────────────────────────────────
	if (roundStep == 4 && spawnTimeCounter == 0) {
		var hardCount  = 0;
		var hardCount2 = 0;
		if (hardRoll == 1) {
			hardCount  = HardModeSpawnsFull.waveSpawnsFullHard1[common_vars.currentRound][currentSpawnIndex];
			hardCount2 = HardModeSpawnsFull.waveSpawnsFullHard1[common_vars.currentRound][currentSpawnIndex];
		}
		if (hardRoll == 2) {
			hardCount  = HardModeSpawnsFull.waveSpawnsFullHard2[common_vars.currentRound][currentSpawnIndex];
			hardCount2 = HardModeSpawnsFull.waveSpawnsFullHard2[common_vars.currentRound][currentSpawnIndex];
		}
		if (hardRoll == 3) {
			hardCount  = HardModeSpawnsFull.waveSpawnsFullHard3[common_vars.currentRound][currentSpawnIndex];
			hardCount2 = HardModeSpawnsFull.waveSpawnsFullHard3[common_vars.currentRound][currentSpawnIndex];
		}
		if (hardRoll == 4) {
			hardCount  = HardModeSpawnsFull.waveSpawnsFullHard4[common_vars.currentRound][currentSpawnIndex];
			hardCount2 = HardModeSpawnsFull.waveSpawnsFullHard4[common_vars.currentRound][currentSpawnIndex];
		}

		if (hardCount == 0 && hardCount2 == 0 && currentSpawnIndex < wave_spawns_indexes.NUM_UNITS) {
			currentSpawnIndex += 1;
		}

		var hardSpawnIdx = currentSpawnIndex;

		if (hardCount > 0 || hardCount2 > 0) {
			if (hardCount > 0) {
				CreateUnitWithProperties(hardCount, wave_spawns_indexes.waveSpawnsUnitIndex[hardSpawnIdx], "spawner", P8, UnitProperty(
					hitpoint = 100, shield = 100, energy = 100, hanger = 8, resource = 0,
					cloaked = False, burrowed = False, intransit = False, hallucinated = False, invincible = False)
				);
			}
			if (hardCount2 > 0) {
				CreateUnitWithProperties(hardCount2, wave_spawns_indexes.waveSpawnsUnitIndex[hardSpawnIdx], "spawner2", P8, UnitProperty(
					hitpoint = 100, shield = 100, energy = 100, hanger = 8, resource = 0,
					cloaked = False, burrowed = False, intransit = False, hallucinated = False, invincible = False)
				);
			}
			currentSpawnIndex += 1;
			spawnTimeCounter = common_vars.delayBetweenSpawns;
		}
	}

	if (roundStep == 4 && spawnTimeCounter > 0) {
		spawnTimeCounter--;
	}

	if (roundStep == 4 && currentSpawnIndex >= wave_spawns_indexes.NUM_UNITS) {
		roundStep = 99;
	}

}