function afterTriggerExec() {
	if (	!Command(P11, Exactly, 1, "Kakaru (Twilight)") ||
			!Command(P9, Exactly, 1, "Terran Civilian")) 
	{
		return;
	}
	DoActions(Wait(3000));
	DoActions(KillUnitAt(All,"(buildings)","spawner",Force1));
	if (Switch("ReduceSpawnsForNumPlayers", Set)) {
		foreach(player : py_range(1, 7)) {
			DoActions(CreateUnit(4, "Zerg Ultralisk", "spawner", P8));
		}
		DoActions(Wait(3000));
		foreach(player : py_range(1, 7)) {
			DoActions(CreateUnit(3, "Terran Firebat", "spawner", P8));
		}
	} else {
		DoActions(CreateUnit(30, "Zerg Ultralisk", "spawner",P8));
		DoActions(Wait(3000));
		DoActions(CreateUnit(20, "Terran Firebat", "spawner", P8));
	}

	DoActions(
		Wait(1500),
		SetSwitch("SpawnExtra", Set),
	);
}