// misc.eps
// Handles: patrol units, ban logic, AI nudge, death/respawn, victory/defeat,
//          shield battery probe-respawn, P12 unit distribution, P9 cleanup,
//          noair zone flushing, energy refill, flag cleanup, build placement
import common_vars;

const deathDelayTimer = EUDArray(7);

// Shared patrol waypoints for all bonus units
const patrolLocs = list(
	py_str("o1"), py_str("o2"), py_str("o22"), py_str("o3"),
	py_str("o31"), py_str("o4"), py_str("o44"), py_str("o5"),
);

// All patrol units — 6 critters + Samir Duran
const patrolUnits = list(
	py_str("Kakaru (Twilight)"),
	py_str("Bengalaas (Jungle)"),
	py_str("Rhynadon (Badlands)"),
	py_str("Scantid (Desert)"),
	py_str("Ursadon (Ice World)"),
	py_str("Ragnasaur (Ashworld)"),
	py_str("Samir Duran (Ghost)"),
);

// Per-unit patrol timers, staggered so they don't all move at once
const patrolTimers = EUDArray(7);

// Ban locations and messages per player slot (Bring-based ban mechanic)
const banLocs = list(
	py_str("ban1"), py_str("ban2"), py_str("ban3"), py_str("ban4"),
	py_str("ban5"), py_str("ban6"), py_str("ban7"),
);

const banMessages = list(
	"\x06Player 1 has been banned!",
	"\x06Player 2 has been banned!",
	"\x06Player 3 has been banned!",
	"\x06Player 4 has been banned!",
	"\x06Player 5 has been banned!",
	"\x06Player 6 has been banned!",
	"\x06Player 7 has been banned!",
);


function onPluginStart() {
	var savedCp = getcurpl();
	foreach(i : py_range(7)) {
		deathDelayTimer[i] = 0;
		patrolTimers[i] = 80 + i * 13;
	}

	// Set all to ally P10/P11/P12
	foreach(player : EUDLoopPlayer(None)) {
		setcurpl(player);
		SetAllianceStatus(P9, Enemy);
		SetAllianceStatus(P10, Ally);
		SetAllianceStatus(P11, Ally);
		SetAllianceStatus(P12, Ally);
	}
	
	// P8 should also ally P9
	setcurpl(P8);
	SetAllianceStatus(P9,  Ally);
	
	// Set pauses to 200 frames
	// dwwrite(0x0058d718, 200); // DEBUG ONLY
	
	setcurpl(savedCp);
}

// ── Generic patrol unit handler — keeps 1 of each critter on the map every minute ──────
function handlePatrolUnit() {
	common_vars.syncRand();
	foreach(i : py_range(7)) {
		if (Command(P9, AtMost, 0, patrolUnits[i])) {
			var spawnIdx = f_rand() % 8;
			foreach(j : py_range(8)) {
				if (spawnIdx == j && (CountdownTimer(Exactly, 55))) {
					CreateUnit(1, patrolUnits[i], patrolLocs[j], P8);
					GiveUnits(1, patrolUnits[i], P8, patrolLocs[j], P9);
				}
			}
		}

		patrolTimers[i] -= 1;
		if (patrolTimers[i] == 0) {
			patrolTimers[i] = 80;
			foreach(j : py_range(8)) {
				if (Bring(P9, AtLeast, 1, patrolUnits[i], patrolLocs[j])) {
					var destIdx = f_rand() % 7;
					if (destIdx >= j) {
						destIdx += 1;
					}
					foreach(k : py_range(8)) {
						if (destIdx == k) {
							Order(patrolUnits[i], P9, patrolLocs[j], Move, patrolLocs[k]);
						}
					}
				}
			}
		}
	}
}

// ── Bring-based ban logic (separate from game_flow.eps Kill-based messages) ──
function handleBans() {
	foreach(i : py_range(7)) {
		if (playerexist(common_vars.micePlayers[i])) {
			var savedCp = getcurpl();
			setcurpl(common_vars.micePlayers[i]);
			if (
				Bring(Force1, AtLeast, 2, "Terran Civilian", banLocs[i]) &&
				Switch("GameStarted", Set)
			) {
				printAllAt(10, banMessages[i]);
				PlayWAVAll("sound/misc/transmission.wav");
				Defeat();
			}
			setcurpl(savedCp);
		}
	}
}

// ── AI nudge: periodically order cat AI to attack ─────────────────────────

function nudgeAIToAttack() {
	common_vars.aiNudgeTimer--;
	if (common_vars.aiNudgeTimer == 0) {
		common_vars.aiNudgeTimer = common_vars.aiNudgeTimerSeconds * 2381 / 100;
		var savedCp = getcurpl();
		setcurpl(P8);
		RunAIScriptAt("SuiR", "playground");
		setcurpl(savedCp);
	}
}

// ── Death + delayed respawn logic ─────────────────────────────────────────
function handleDeaths() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		if (
			Command(player, Exactly, 0, "Protoss Probe") &&
			Command(player, Exactly, 0, "Protoss Shield Battery") &&
			Command(player, Exactly, 0, "Flag") &&
			deathDelayTimer[player] == 0
		) {
			common_vars.P1DisplayDebug($T("[DBG misc] death triggered for a player"));
			var savedCp = getcurpl();
			setcurpl(player);
			PlayWAV("sound/misc/transmission.wav");
			DisplayText("\x06- You have died!");
			setcurpl(savedCp);
			KillUnitAt(All, "(buildings)", "playground", player);
			KillUnitAt(All, "Terran SCV",  "playground", player);
			deathDelayTimer[player] = 48;
		}

		if (deathDelayTimer[player] > 0) {
			deathDelayTimer[player] -= 1;
			if (deathDelayTimer[player] == 2) {
				KillUnitAt(All, "Men",  "playground", player);
				CreateUnit(1, "Flag", "Start", player);
			}
		}
	}
}

// ── Shield battery probe-respawn ──────────────────────────────────────────
// Classic: "Player N Command(CP,Probe,==0) + Command(CP,ShieldBattery,>=1) Preserve"
// When a mouse has no probe but has a shield battery (their respawn anchor),
// respawn the probe at the battery's tracked location then remove the battery.
function handleShieldBatteryRespawn() {
	foreach(i : py_range(7)) {
		var player = common_vars.micePlayers[i];
		if (
			Command(player, Exactly,  0, "Protoss Probe") &&
			Command(player, AtLeast, 1, "Protoss Shield Battery")
		) {
			common_vars.P1DisplayDebug($T("[DBG misc] shield battery respawn fired"));
			KillUnitAt(1, "Flag",                    "Start",                       player);
			CreateUnit(1, "Protoss Probe",            common_vars.afterlifeLocs[i],  player);
			KillUnitAt(1, "Protoss Shield Battery",   common_vars.afterlifeLocs[i],  player);
		}
	}
}

function handleCannonCountAndLimit() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		var savedCp = getcurpl();
		var count = 0;
		
		foreach(n : py_range(1, 222)) {
			if (Command(player, AtLeast, n, "Protoss Photon Cannon")) {
				count = n;
			}
		}
		setcurpl(player);
		
		if (count >= 221) {
			common_vars.P1DisplayDebug($T("[DBG misc] cannon max limit respawn fired"));
			KillUnitAt(1, "Protoss Photon Cannon", "Anywhere", player);
			SetResources(player, Add, 20, Ore);
			PlayWAV("sound/misc/transmission.wav");
			DisplayTextAt(10, "\x06- Only 220 Cannons allowed!");
			count -= 1;
		}
		printAt(0, "\x12\x1ECannons: {} / 220", count);
		setcurpl(savedCp);
	}
}

// ── Game speed setting ──────────────────────────────────────────
function checkGameSpeedChanger() {
	if (Bring(P1, Exactly, 1, "Terran Civilian", "Speed 1x")) {
		dwwrite(0x5124F0, 42);
		DisplayTextAll("");
		printAllAt(10, "\x13\x04Speed set to Regular");
		MoveUnit(1, "Terran Civilian", P1, "Speed 1x", "SpeedArea");
	}
	if (Bring(P1, Exactly, 1, "Terran Civilian", "Speed 1.25x")) {
		dwwrite(0x5124F0, 33);
		DisplayTextAll("");
		printAllAt(10, "\x13\x04Speed set to 1.25x. Also closest to 30fps!");
		MoveUnit(1, "Terran Civilian", P1, "Speed 1.25x", "SpeedArea");
	}
	if (Bring(P1, Exactly, 1, "Terran Civilian", "Speed 1.5x")) {
		dwwrite(0x5124F0, 28);
		DisplayTextAll("");
		printAllAt(10, "\x13\x04Speed set to 1.5x");
		MoveUnit(1, "Terran Civilian", P1, "Speed 1.5x", "SpeedArea");
	}

	
	
	//speeds: fastest: 42;
	//speeds: 1x:   36
	//speeds: 1.25: 33 // also 30fps
	//speeds: 1.5:  28
	//speeds: 1.75: 24
	//speeds: 2:    21
	
	
	
}


// ── P12 unit distribution ─────────────────────────────────────────────────
// Classic: "Mices Command(P12,Men,>=1) Preserve → GiveUnits P12→CP at playground/HeroConvert/DifficultyBox"
// Classic: "Mices Command(P12,Buildings,>=1) Preserve → GiveUnits P12→CP at playground"
// Classic: "Mices Always Preserve → KillUnitAt(P12, Flag, 1, Start)"
// P12 acts as the hero-selector host — units pooled there get distributed to each mice player
function handleP12Units() {
	// Always clean up any stray P12 flags at Start
	KillUnitAt(1, "Flag", "Start", P12);

	foreach(player : EUDLoopPlayer(None, Force1)) {
		if (Command(P12, AtLeast, 1, "Men")) {
			SetInvincibility(Disable, "Protoss Probe", P12, "Anywhere");
			common_vars.P1DisplayDebug($T("[DBG misc] P12 men distribution fired"));
			GiveUnits(1, "Men",       P12, "playground",   player);
			GiveUnits(1, "Men",       P12, "Hero Convert",  player);
		//	GiveUnits(1, "(any unit)", P12, "DifficultyBox", player); // shouldn't be needed mid game, ever
		}
		if (Command(P12, AtLeast, 1, "Buildings")) {
			common_vars.P1DisplayDebug($T("[DBG misc] P12 buildings distribution fired"));
			GiveUnits(1, "Buildings", P12, "playground", player);
		}
	}
}

// ── P9 playground cleanup ─────────────────────────────────────────────────
// Classic: "All players Always Preserve → KillUnitAt P9 probe/buildings/flags at playground"
// P9 is the "neutral threat" player; stray units in playground staging area must be culled
function handleP9Cleanup() {
	KillUnitAt(All, "Protoss Probe", "playground", P9);
	KillUnitAt(All, "Buildings",     "playground", P9);
	KillUnitAt(All, "Flag",          "playground", P9);
}

// ── Noair zone flushing (GameStarted only) ────────────────────────────────
// Classic: "Mices GameStarted Preserve → MoveUnit(CP, any unit, All, noair, Start)"
// Classic: "Cats  GameStarted Preserve → MoveUnit(CP, any unit, All, noair, Start) + P9"
// Keeps the noair staging corridor clear of stray units during gameplay
function handleNoairFlush() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		MoveUnit(All, "(any unit)", player, "noair", "Start");
	}
	MoveUnit(All, "(any unit)", P8, "noair", "Start");
	MoveUnit(All, "(any unit)", P9, "noair", "Start");
}

// ── Misc per-player cleanup ───────────────────────────────────────────────
// Classic: "Mices Command(CP,Probe,>=1) Preserve → KillUnit(CP, Flag)"
//          "Mices Bring(CP,Flag,Start,>=1) + Bring(CP,Probe,Start,>=1) → RemoveUnit(Mices,Flag)"
// Ensures flags (death markers) are cleaned up when the probe is alive
function handleFlagCleanup() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		if (Command(player, AtLeast, 1, "Protoss Probe")) {
			KillUnit("Flag", player);
		}
		if (
			Bring(player, AtLeast, 1, "Flag",         "Start") &&
			Bring(player, AtLeast, 1, "Protoss Probe", "Start")
		) {
			RemoveUnit("Flag", Force1);
		}
	}
}

// ── Energy refill for support units ──────────────────────────────────────
// Classic: "Mices Always Preserve → ModifyUnitEnergy(CP, Medic/ShieldBattery, 100, All, playground)"
// Keeps medics and shield batteries at full energy while in the playground staging zone
// ⚠ VERIFY parameter order at compile time: (count, unit, amount%, player, location)
function handleEnergyRefill() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		ModifyUnitEnergy(All, "Terran Medic",player,"playground",100);
		ModifyUnitEnergy(All,"Protoss Shield Battery",player,"playground",100);
	}
}

// ── Build placement helpers ───────────────────────────────────────────────
// Classic: "Mices Command(CP,Cocoon,>=1) Preserve"
//          When a unit morphs into a Cocoon (e.g. Defiler ability), snap Pylon1 location
//          to the cocoon, destroy any existing pylon there, then remove the cocoon.
//          This acts as a placement trigger for the cocoon-based building system.
// Classic: "Mices Command(CP,LurkerEgg,>=1) Preserve"
//          Lurker can't be built directly — route through egg placement trick.
// Classic: "Mices Command(CP,ZergEgg,>=1) Preserve"
//          Drone starport build trick — eggs placed via starport become drones.
//
// MoveLocation(locationToMove, unit, player, Source Location) — no setcurpl needed
function handleBuildPlacement() {
	foreach(player : EUDLoopPlayer(None, Force1)) {
		// Cocoon placement (e.g. Defiler ability, pylon remover)
		if (Command(player, AtLeast, 1, "Cocoon")) {
			common_vars.P1DisplayDebug($T("[DBG misc] cocoon placement fired"));
			MoveLocation("Pylon1", "Cocoon", player, "Anywhere" );
			KillUnitAt(All, "Protoss Pylon", "Pylon1", player   );
			RemoveUnitAt(All, "Cocoon",      "Pylon1", player   );
		}

		// Lurker egg → Lurker build trick
		if (Command(player, AtLeast, 1, "Zerg Lurker Egg")) {
			common_vars.P1DisplayDebug($T("[DBG misc] lurker egg placement fired"));
			MoveLocation("Pylon2", "Zerg Lurker Egg",player, "Anywhere");
			RemoveUnitAt(1, "Zerg Lurker Egg",     "Pylon2", player);
			CreateUnit(1, "Zerg Lurker",           "Pylon2", player);
		}

		// Zerg egg → Drone build trick (starport drone purchase)
		if (Command(player, AtLeast, 1, "Zerg Egg")) {
			common_vars.P1DisplayDebug($T("[DBG misc] zerg egg placement fired"));
			MoveLocation("Pylon3", "Zerg Egg",    player, "Anywhere");
			RemoveUnitAt(1, "Zerg Egg",                 "Pylon3",   player);
			CreateUnit(1, "Zerg Drone",                 "Pylon3",   player);
		}
	}
}

function handleComputerVisionObserver() {
	setcurpl(P8);
	if (Command(P8, AtLeast, 1, "Protoss Observer")) {
		RunAIScriptAt("+Vi0", "Anywhere");
		RunAIScriptAt("+Vi1", "Anywhere");
		RunAIScriptAt("+Vi2", "Anywhere");
		RunAIScriptAt("+Vi3", "Anywhere");
		RunAIScriptAt("+Vi4", "Anywhere");
		RunAIScriptAt("+Vi5", "Anywhere");
		RunAIScriptAt("+Vi6", "Anywhere");
	} else {
		RunAIScriptAt("-Vi0", "Anywhere");
		RunAIScriptAt("-Vi1", "Anywhere");
		RunAIScriptAt("-Vi2", "Anywhere");
		RunAIScriptAt("-Vi3", "Anywhere");
		RunAIScriptAt("-Vi4", "Anywhere");
		RunAIScriptAt("-Vi5", "Anywhere");
		RunAIScriptAt("-Vi6", "Anywhere");
	}
	
}


function afterTriggerExec() {
	var savedCp = getcurpl();
	
	// ── Always-running sections (no GameStarted gate) ─────────────────────
	handleP9Cleanup();
	handleP12Units();
	handleFlagCleanup();
	handleShieldBatteryRespawn();
	handleBuildPlacement();
	handleEnergyRefill();

	if (!Switch("GameStarted", Set)) {
		return;
	}

	// ── GameStarted-only sections ─────────────────────────────────────────
	handleNoairFlush();
	handleDeaths();
	handlePatrolUnit();
	nudgeAIToAttack();
	handleBans();
	handleComputerVisionObserver();

	// ── Victory: all cat units gone after round 4+ ────────────────────────
	if (
		common_vars.currentRound >= 4 &&
		Command(P8, Exactly, 0, "(any unit)")
	) {
		common_vars.P1DisplayDebug($T("[DBG misc] VICTORY condition fired"));
		common_vars.currentRound = 0;
		printAllAt(10, "\x13\x07 The cats have been defeated. You WIN! Now go touch some grass");
		foreach(player : EUDLoopPlayer(None, Force1)) {
			setcurpl(player);
			Victory();
		}
	}

	if (
		common_vars.currentRound >= 2 &&
		Command(Force1, Exactly, 0, "Protoss Probe") &&
		Command(Force1, Exactly, 0, "Terran SCV") &&
		Command(Force1, Exactly, 0, "Protoss Shield Battery")
	) {
		common_vars.P1DisplayDebug($T("[DBG misc] DEFEAT condition fired"));
		common_vars.currentRound = 0;
		DisplayTextAll("");
		DisplayTextAll("");
		DisplayTextAll("");
		printAllAt(8, "\x13\x06 All the mice are dead. You LOSE! Git gud.");
		printAllAt(9, "\x13\x06 All the mice are dead. You LOSE! Git gud.");
		printAllAt(10, "\x13\x06 All the mice are dead. You LOSE! Git gud.");
		foreach(player : EUDLoopPlayer(None, Force1)) {
			setcurpl(player);
			Defeat();
		}
	}
	
	
	// Disable fog of war updates, to be used BEFORE KillUnit("Map Revealer", AllPlayers);
	SetMemory(0x0051CE98, SetTo, 0);
	
	
	// Check for Debug being enabled
	setcurpl(P1);
	if (
		(   Bring(P1, AtLeast, 1, "Terran Civilian", "P1EnableDebug") &&
			Bring(P1, AtLeast, 1, "Terran Civilian", "P1EnableDebug2")
		) && common_vars.P1EnableDebug.IsCleared()
	) {
		DoActions(common_vars.P1EnableDebug.Set());
		DisplayText("[DBG] Debug ENABLED");
	} else if (
		(   Bring(P1, Exactly, 0, "Terran Civilian", "P1EnableDebug") ||
			Bring(P1, Exactly, 0, "Terran Civilian", "P1EnableDebug2")
		) && common_vars.P1EnableDebug.IsSet()
	) {
		DoActions(common_vars.P1EnableDebug.Clear());
		DisplayText("[DBG] Debug DISABLED");
	}
	
	handleCannonCountAndLimit();
	checkGameSpeedChanger();
	
	setcurpl(savedCp);
}
