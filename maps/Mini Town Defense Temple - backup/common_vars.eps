// common_vars.eps
// Shared runtime state for EPScript plugins.
// Data-only module: import from other .eps files, but do NOT list this file in the .edd.

// Set while a boss wave is pending/spawning/alive.
// This blocks countdown reset during the no-unit delay between countdown 0 and first spawn.
var bossWaveActive = 0;

// Human-readable leaderboard rotation state.
// 0 = Experience, 1+ = wave-specific kill boards.
var leaderboardMode = 0;
var leaderboardTimer = 0;

// startup grace period
var waveStartupGraceInit = 12;
// Set once the final bonus wave starts. Used for victory vs defeat logic.
var finalWaveReached = 0;

const playerList = list(P1, P2, P3, P4, P5, P6, P7, P8);
const visionShare = list("+Vi0","+Vi1","+Vi2","+Vi3","+Vi4","+Vi5","+Vi6","+Vi7");
const visionShareP8 = list("-Vi0","-Vi1","-Vi2","-Vi3","-Vi4","-Vi5","+Vi6","+Vi7");

// Number of active human players
var numPlayers = 0;


// Easy Mode enabled? (Currently just makes HP of enemies be 1/5 * number of players)
var EasyModeEnable = 0;
var currentWave = 0;