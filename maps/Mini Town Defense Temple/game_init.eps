// game_init.eps
// One-shot game setup: alliances, AI scripts, mission objectives,
// starting gold, intro pings, town-attack warning, P12 cleanup. Wave countdown reset is handled by wave_spawns.eps.
//
// RULE: save getcurpl() at top of every function, restore at very bottom.
// SetAllianceStatus(targetPlayer, status) -- acts on CurrentPlayer
// RunAIScript(Script)                     -- acts on CurrentPlayer
// Order(unit, player, startArea, order, targetLoc) -- Patrol is a bare constant

import common_vars;

var dtStatusFlagAddr = 0;

var introTimer = 256;
var townAttackWarnShown = 0;

function onPluginStart() {
	const cp = getcurpl();

	// ── Alliance setup ──────────────────────────────────────────────────────
	setcurpl(P7);
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		SetAllianceStatus(player, Ally);
	}
	setcurpl(P7);
	SetAllianceStatus(P8, Enemy);

	setcurpl(P8);
	SetAllianceStatus(P7, Enemy);
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		SetAllianceStatus(player, Enemy);
	}
	
	// Set CPU to see P9-12 as allys too
	SetAllianceStatus(P9, Ally);
	SetAllianceStatus(P10, Ally);
	SetAllianceStatus(P11, Ally);
	SetAllianceStatus(P12, Ally);

	// ── First set all P1-P7 to see everyone else ─────────────────────────────────────────
	foreach(i : py_range(7)) {
		setcurpl(common_vars.playerList[i]);
		foreach(i : py_range(8)) {
			RunAIScript(common_vars.visionShare[i]);
		}
	}

	
	// 	── Then take it away so P8 cannot see cloaked/burrowed P1-P6 units ────────────────────────────────────
	setcurpl(P8);
	foreach(i : py_range(8)) {
		RunAIScript(common_vars.visionShareP8[i]);
	}
		
		
	// ── Starting gold ───────────────────────────────────────────────────────
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		SetResources(player, Add, 200, Ore);
	}

	// ── Mission objectives ──────────────────────────────────────────────────
	SetMissionObjectivesAll("Levels at 500, 1k, 2k, 3k, 5k, 7k, 10k, 15k, 20k, 25k, 35k, 50k, 75k, 100k, 130k, 170k, 220k, 280k, 350k, and 400k experience. Rewards up to 20,000 minerals.\r\n\r\n\x04open source: github @Kupie/starcraft_maps");

	introTimer = 256;
	
	
	// ── Try to get CPU to rebuild town  ────────────────────────────
	setcurpl(P7);
	SetResources(P7, Add, 50000, OreAndGas);
	RunAIScriptAt("Terran Expansion Custom Level", "CPUTown"); // Terran AI
	
	
	// ───── spawn dark templar (hero) after setting it as NOT perm cloaked, then reset unit data back to be cloaked ───────────────────
	// ───── This makes it visible for everyone when picking heroes, as there's only one P9 dark templar pre-placed on the map for hero selection───────────
	MoveLocation("_temp","Dark Templar (Hero)",P9,"Anywhere");
	RemoveUnitAt(1,"Dark Templar (Hero)","_temp",P9);
	SetMemory(0x6641A8, Add, -0x400000); // units:Special Ability Flags  index:74 (Dark Templar Hero) disable permanent cloaking
	CreateUnit(1, "Dark Templar (Hero)", "_temp", P7);
	GiveUnits(All, "Dark Templar (Hero)", P7, "_temp", P9);
	
	// Reset it for when actually picking heroes
	SetMemory(0x6641A8, Add, 0x400000); // units:Special Ability Flags  index:74 (Dark Templar Hero) enable permanent cloaking

	// Set pauses to 200
	dwwrite(0x0058d718, 200);
	
	setcurpl(cp);
	
}

function afterTriggerExec() {
	const cp = getcurpl();

	// ── Intro sequence countdown ────────────────────────────────────────────
	// introTimer counts down from 256 to 0.
	//
	// Phase 1 — Temple warning  (t=256..171): eprintAll flashes between
	//   red \x06 and yellow \x04, alternating every 15 frames via % 30.
	//   Sound + minimap ping + CenterView only on the very first show (t=255).
	//
	// Phase 2 — Hero select     (t=170..61):  eprintAll flashes between
	//   white \x04 and green \x07, alternating every 15 frames via % 30.
	//   Sound + CenterView + minimap ping only on the very first show (t=169).
	//   Minimap pings repeat at t=122, 98, 74.
	//
	// Phase 3 — Changelog       (t=60 and t=0): printAllAt lines 0-8.
	//   eprintAll hero prompt re-shown with sound at both t=60 and t=0
	//   so it stays visible through the end of the sequence.
	//
	// eprintAll is the error-message area (below screen center) —
	// completely separate from the printAllAt scroll lines 0-10.

	if (introTimer >= 1) {
		introTimer--;

		// ── Phase 1: Temple warning flash (t=255..171) ───────────────────
		if (introTimer >= 171 && introTimer <= 255) {
			// First frame only: sound + minimap + center view
			if (introTimer == 255) {
				PlayWAVAll("sound/misc/transmission.wav");
				MinimapPingAll("Temple");
				CenterViewAll("Temple");
			}
			// Flash every 15 frames: remainder 0 = white, remainder 15 = yellow
			var templeRem = introTimer % 30;
			if (templeRem == 0)  { eprintAll("\x04YOU MUST DEFEND THE TEMPLE.  Every round!"); }
			if (templeRem == 15) { eprintAll("\x03YOU MUST DEFEND THE TEMPLE.  Every round!"); }
		}

		// ── Phase 2: Hero select flash (t=170..61) ───────────────────────
		if (introTimer >= 0 && introTimer <= 170) {
			// First frame only: sound + center view
			if (introTimer == 170) {
				PlayWAVAll("sound/misc/transmission.wav");
				CenterViewAll("_Heropick");
			}
			// Flash every 15 frames: remainder 15 = green, remainder 0 = white
			var heroRem = introTimer % 30;
			if (heroRem == 0)  { eprintAll("\x04Now Select Your Hero and get some cash!"); }
			if (heroRem == 15) { eprintAll("\x07Now Select Your Hero and get some cash!"); }
		}

		// Minimap pings for hero area
		if (introTimer == 122) { MinimapPingAll("_Heropick"); }
		if (introTimer == 98)  { MinimapPingAll("_Heropick"); }
		if (introTimer == 74)  { MinimapPingAll("_Heropick"); }

		// ── Phase 3a: Changelog first display (t=80) ─────────────────────
		if (introTimer == 80) {
			printAllAt(0, "\x13\x12Map revamped with EUD + Turbo triggers by Kupie 2026");
			printAllAt(1, "\x13\x12Testing version 1");
			printAllAt(2, "\x13\x12open source: https://github.com/Kupie/starcraft_maps");
		//	printAllAt(3, "");
			printAllAt(4, "\x13\x12Gameplay changes:");
			printAllAt(5, "\x13\x12- Marine/Firebat heroes permastimmed");
			printAllAt(6, "\x13\x12- Firebat slightly nerfed");
			printAllAt(7, "\x13\x12- Zerg heroes share the same attack upgrade");
			printAllAt(8, "\x13\x12- Upgrades/Recruit available at every upgrade building");
		//	PlayWAVAll("sound/misc/transmission.wav");
			//Order("Dark Templar (Hero)",P7,"Anywhere",1,"Anywhere");
		}

		// ── Phase 3b: Changelog re-display (t=0) — refreshes before expiry
		if (introTimer == 1) {
			//Order("Dark Templar (Hero)",P7,"Anywhere",1,"Anywhere");
			
		}
		// ── Phase 3b: Changelog re-display (t=0) — refreshes before expiry
		if (introTimer == 0) {
			printAllAt(0, "\x13\x12Map revamped with EUD + Turbo triggers by Kupie 2026");
			printAllAt(1, "\x13\x12Testing version 1");
			printAllAt(2, "\x13\x12open source: https://github.com/Kupie/starcraft_maps");
		//	printAllAt(3, "");
			printAllAt(4, "\x13\x12Gameplay changes:");
			printAllAt(5, "\x13\x12- Marine/Firebat heroes permastimmed");
			printAllAt(6, "\x13\x12- Firebat slightly nerfed");
			printAllAt(7, "\x13\x12- Zerg heroes share the same attack upgrade");
			printAllAt(8, "\x13\x12- Upgrades/Recruit available at every upgrade building");
		//	PlayWAVAll("sound/misc/transmission.wav");
		}
	}



	// ── Town-attack warning + hero retreat (timer 5) ──────────────────────
	if (CountdownTimer(Exactly, 5) && townAttackWarnShown == 0) {
		townAttackWarnShown = 1;	
		foreach(player : EUDLoopPlayer("Human", Force1)) {
			setcurpl(player);
	
			if (Command(player, AtLeast, 1, "Gui Montag (Firebat)") ||
				Command(player, AtLeast, 1, "Tassadar/Zeratul (Archon)")) {
				DisplayText("\x13\x03Our Town Is Under Attack!\r\n\r\n\x13\x03\x06Sorry No Splash Units Allowed During Town Attack!\r\n\r\n\r\n\r\n\r\n");
			} else {
				DisplayText("\x13\x03Our Town Is Under Attack!\r\n\r\n\r\n\r\n\r\n\r\n\r\n");
			}
	
			MoveUnit(All, "(men)", player, "_Alltraining", "_healing");
			MoveUnit(All, "(men)", player, "_Trainingpick", "_healing");
		}
	}

	// ── TSUx re-run at countdown 200 ───────────────────────────────────────
	if (CountdownTimer(Exactly, 200)) {
		townAttackWarnShown = 0;
	}

	// ── Heroes stay allied to each other and P7 every frame ─────────────────
	foreach(player : EUDLoopPlayer("Human", Force1)) {
		setcurpl(player);
		foreach(ally : EUDLoopPlayer("Human", Force1)) {
			SetAllianceStatus(ally, Ally);
		}
		SetAllianceStatus(P7, Ally);
	}

	// ── Kill rogue P12 units ────────────────────────────────────────────────
	if (Bring(P12, AtLeast, 1, "(men)", "Anywhere")) {
		KillUnit("(men)", P12);
	}
	
	var mtxmAddr = dwread(0x5993C4);
	var mapWidth = 96;
	var x = 9;
	var y = 11;
	var tileID = 110;
	// then access tile at (x, y):
	wwrite(mtxmAddr + (y * mapWidth + x) * 2, tileID);

	// ── Every-frame cloak clear on P9 Dark Templar ──────────────────────────
	// Engine re-applies cloak each frame for permanently cloaked units,
	// so we must clear these bits every frame.
	// we clear RequiresDetection and Cloaked so the unit is selectable, then use a placed "sprite only" since I can't figure out making the unit look normal yet
	// dtStatusFlagAddr is set in onPluginStart when the unit is found.
	if (dtStatusFlagAddr >= 1) {
		SetMemoryX(dtStatusFlagAddr, SetTo, 0, 0x00000300);	// clears bits 0x100, 0x200, 0x800
		
	}

	setcurpl(cp);
}
