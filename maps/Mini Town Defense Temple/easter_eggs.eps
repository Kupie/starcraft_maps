// easter_eggs.eps
// Chat command detection via chatEvent + MSQC sync using PVariable.
//
// chatFlag[player] gets written by MSQC with the sum of all active chat bits.
// flagCheck decodes from highest bit to lowest, firing each active cheat
// and subtracting its value so lower bits still fire correctly.
//
// Chat map:
//   65536 = cheat p
//   32768 = cheat o
//   16384 = cheat n
//   8192  = cheat m
//   4096  = cheat l
//   2048  = cheat k
//   1024  = cheat j
//   512   = cheat i
//   256   = cheat h
//   128   = cheat g
//   64    = cheat f
//   32    = cheat e
//   16    = cheat d
//   8     = "the gathering"      (infinite energy toggle)
//   4     = "food for thought"   (supply used zeroing toggle)
//   2     = "power overwhelming" (god mode toggle)
//
// Supply used addresses (per-player, 4 bytes each, players 1-8):
//   Zerg:    0x582174..0x582190
//   Terran:  0x582204..0x582220
//   Protoss: 0x582294..0x5822B0
//
// RULE: save getcurpl() at top, restore at very bottom only.

import common_vars;

const chatFlag = PVariable();
EUDRegisterObjectToNamespace("chatFlag", chatFlag);

var cheatGodActive    = 0;	// "power overwhelming" toggle (0=off, 1=on)
var cheatFoodActive   = 0;	// "food for thought" toggle   (0=off, 1=on)
var cheatEnergyActive = 0;	// "the gathering" toggle      (0=off, 1=on)

function afterTriggerExec() {
	const cp = getcurpl();

	// ── Chat detection ────────────────────────────────────────────────────
	foreach(player : EUDLoopPlayer("Human")) {
		if (chatFlag[player] >= 1) {
			var flagCheck = chatFlag[player];
			chatFlag[player] = 0;

			// ── Decode from highest bit to lowest ─────────────────────────
			if (flagCheck >= 65536) {
				DisplayTextAll("\x07cheat p detected");
				flagCheck = flagCheck - 65536;
			}
			if (flagCheck >= 32768) {
				DisplayTextAll("\x07cheat o detected");
				flagCheck = flagCheck - 32768;
			}
			if (flagCheck >= 16384) {
				DisplayTextAll("\x07cheat n detected");
				flagCheck = flagCheck - 16384;
			}
			if (flagCheck >= 8192) {
				DisplayTextAll("\x07cheat m detected");
				flagCheck = flagCheck - 8192;
			}
			if (flagCheck >= 4096) {
				DisplayTextAll("\x07cheat l detected");
				flagCheck = flagCheck - 4096;
			}
			if (flagCheck >= 2048) {
				DisplayTextAll("\x07cheat k detected");
				flagCheck = flagCheck - 2048;
			}
			if (flagCheck >= 1024) {
				DisplayTextAll("\x07cheat j detected");
				flagCheck = flagCheck - 1024;
			}
			if (flagCheck >= 512) {
				DisplayTextAll("\x07cheat i detected");
				flagCheck = flagCheck - 512;
			}
			if (flagCheck >= 256) {
				DisplayTextAll("\x07cheat h detected");
				flagCheck = flagCheck - 256;
			}
			if (flagCheck >= 128) {
				DisplayTextAll("\x07cheat g detected");
				flagCheck = flagCheck - 128;
			}
			if (flagCheck >= 64) {
				DisplayTextAll("\x07cheat f detected");
				flagCheck = flagCheck - 64;
			}
			if (flagCheck >= 32) {
				DisplayTextAll("\x07cheat e detected");
				flagCheck = flagCheck - 32;
			}
			if (flagCheck >= 16) {
				DisplayTextAll("\x07cheat d detected");
				flagCheck = flagCheck - 16;
			}
			if (flagCheck >= 8) {
				// ── "the gathering" toggle ────────────────────────────────
				if (cheatEnergyActive == 0) {
					cheatEnergyActive = 1;
					DisplayTextAll("\x04The Gathering: ON. All Wizards Have Prune Juice.");
				} else {
					cheatEnergyActive = 0;
					DisplayTextAll("\x07The Gathering: OFF. Wizards Have Run Out of Prune Juice.");
				}
				flagCheck = flagCheck - 8;
			}
			if (flagCheck >= 4) {
				// ── "food for thought" toggle ─────────────────────────────
				if (cheatFoodActive == 0) {
					cheatFoodActive = 1;
					DisplayTextAll("\x04Food for Thought: ON. Supply? Never Heard of It.");
				} else {
					cheatFoodActive = 0;
					DisplayTextAll("\x07Food for Thought: OFF. Pay Your Supply Debt.");
				}
				flagCheck = flagCheck - 4;
			}
			if (flagCheck >= 2) {
				// ── "power overwhelming" toggle ───────────────────────────
				if (cheatGodActive == 0) {
					cheatGodActive = 1;
					DisplayTextAll("\x06Power Overwhelming: ON. Absolute Spineless Worm.");
				} else {
					cheatGodActive = 0;
					DisplayTextAll("\x07Power Overwhelming: OFF. Welcome Back to Mortality.");
				}
				flagCheck = flagCheck - 2;
			}
			// flagCheck should be 0 here if all bits accounted for
		}
	}

	// ── Per-frame: god mode ───────────────────────────────────────────────
	if (cheatGodActive == 1) {
		foreach(player : EUDLoopPlayer("Human")) {
			ModifyUnitHitPoints(All, AllUnits, player, Anywhere, 100);
		}
	}

	// ── Per-frame: infinite energy ────────────────────────────────────────
	if (cheatEnergyActive == 1) {
		foreach(player : EUDLoopPlayer(None)) {
			ModifyUnitEnergy(All, AllUnits, player, Anywhere, 100);
		}
	}

	// ── Per-frame: supply zeroing ─────────────────────────────────────────
	// Zeroes supply used for human players only, all three races.
	// Base addresses confirmed from in-game trigger format (decimal -> hex):
	//   Zerg    base: 5775732 = 0x582174  (+ player*4 per player)
	//   Terran  base: 5775876 = 0x582204  (+ player*4 per player)
	//   Protoss base: 5776020 = 0x582294  (+ player*4 per player)
	if (cheatFoodActive == 1) {
		foreach(player : EUDLoopPlayer("Human")) {
			dwwrite(0x582174 + player * 4, 0);  // Zerg Control Used
			dwwrite(0x582204 + player * 4, 0);  // Terran Supply Used
			dwwrite(0x582294 + player * 4, 0);  // Protoss Psi Used
		}
	}

	setcurpl(cp);
}
