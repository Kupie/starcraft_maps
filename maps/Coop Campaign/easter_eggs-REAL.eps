// easter_eggs.eps
// Chat command detection via chatEvent + MSQC sync.
//
// chatEvent index == MSQC condition == deaths value added == DeathsX mask.
// All are the same power-of-2 number. No translation needed.
//
// Deaths counter registry: "Unused type   2"
//   2     = "power overwhelming" (god mode toggle)
//   4     = "food for thought"   (supply used zeroing toggle)
//   8     = "the gathering" 	(infinite energy for ALL units)
//   16    = cheat5
//   32    = cheat6
//   64    = cheat7
//   128   = cheat8
//   256   = cheat9
//   512   = cheat10
//   1024  = cheat11
//   2048  = cheat12
//   4096  = cheat13
//   8192  = cheat14
//   16384 = cheat15
//   32768 = cheat16
//
// Supply used addresses (per-player, 4 bytes each):
//   Zerg:    0x582174 + player*4  (players 1-8: 0x582174..0x582190)
//   Terran:  0x582204 + player*4  (players 1-8: 0x582204..0x582220)
//   Protoss: 0x582294 + player*4  (players 1-8: 0x582294..0x5822B0)
//
// RULE: save getcurpl() at top, restore at very bottom only.

var cheatGodActive  = 0;	// "power overwhelming" toggle (0=off, 1=on)
var cheatFoodActive = 0;	// "food for thought" toggle   (0=off, 1=on)
var cheatEnergyActive = 0;	// "the gathering" toggle   (0=off, 1=on)

function afterTriggerExec() {
	const cp = getcurpl();

	foreach(player : EUDLoopPlayer("Human")) {
		// ── "power overwhelming" (toggle) ─────────────────────────────────
		if (DeathsX(player, Exactly, 2, "Unused type   2", 2) && cheatGodActive == 0) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 2);
			cheatGodActive = 1;
			eprintAll("\x06Power Overwhelming: ON. Absolute Spineless Worm.");
		} else if (DeathsX(player, Exactly, 2, "Unused type   2", 2) && cheatGodActive == 1) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 2);
			cheatGodActive = 0;
			eprintAll("\x07Power Overwhelming: OFF. Welcome Back to Mortality.");
		}

		// Per-frame god mode: restore all units to full HP each frame
		if (cheatGodActive == 1) {
			ModifyUnitHitPoints(All, AllUnits, player, Anywhere, 100);
		}

		// ── "food for thought" (toggle) ───────────────────────────────────
		if (DeathsX(player, Exactly, 4, "Unused type   2", 4) && cheatFoodActive == 0) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 4);
			cheatFoodActive = 1;
			eprintAll("\x04Food for Thought: ON. Supply? Never Heard of It.");
		} else if (DeathsX(player, Exactly, 4, "Unused type   2", 4) && cheatFoodActive == 1) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 4);
			cheatFoodActive = 0;
			eprintAll("\x07Food for Thought: OFF. Pay Your Supply Debt.");
		}

		// ── "the gathering" (toggle, all players) ─────────────────────────────────
		if (DeathsX(player, Exactly, 8, "Unused type   2", 8) && cheatEnergyActive == 0) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 8);
			cheatEnergyActive = 1;
			eprintAll("\x04All Wizards have prune juice.");
		} else if (DeathsX(player, Exactly, 8, "Unused type   2", 8) && cheatEnergyActive == 1) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 8);
			cheatEnergyActive = 0;
			eprintAll("\x04Wizards have ran out of prune juice.");
		}


		// ── cheat5 ────────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 16, "Unused type   2", 16)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 16);
			setcurpl(player);
			eprintAll("\x07cheat5 detected");
		}

		// ── cheat6 ────────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 32, "Unused type   2", 32)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 32);
			setcurpl(player);
			eprintAll("\x07cheat6 detected");
		}

		// ── cheat7 ────────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 64, "Unused type   2", 64)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 64);
			setcurpl(player);
			eprintAll("\x07cheat7 detected");
		}

		// ── cheat8 ────────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 128, "Unused type   2", 128)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 128);
			setcurpl(player);
			eprintAll("\x07cheat8 detected");
		}

		// ── cheat9 ────────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 256, "Unused type   2", 256)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 256);
			setcurpl(player);
			eprintAll("\x07cheat9 detected");
		}

		// ── cheat10 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 512, "Unused type   2", 512)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 512);
			setcurpl(player);
			eprintAll("\x07cheat10 detected");
		}

		// ── cheat11 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 1024, "Unused type   2", 1024)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 1024);
			setcurpl(player);
			eprintAll("\x07cheat11 detected");
		}

		// ── cheat12 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 2048, "Unused type   2", 2048)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 2048);
			setcurpl(player);
			eprintAll("\x07cheat12 detected");
		}

		// ── cheat13 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 4096, "Unused type   2", 4096)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 4096);
			setcurpl(player);
			eprintAll("\x07cheat13 detected");
		}

		// ── cheat14 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 8192, "Unused type   2", 8192)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 8192);
			setcurpl(player);
			eprintAll("\x07cheat14 detected");
		}

		// ── cheat15 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 16384, "Unused type   2", 16384)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 16384);
			setcurpl(player);
			eprintAll("\x07cheat15 detected");
		}

		// ── cheat16 ───────────────────────────────────────────────────────
		if (DeathsX(player, Exactly, 32768, "Unused type   2", 32768)) {
			SetDeathsX(player, SetTo, 0, "Unused type   2", 32768);
			setcurpl(player);
			eprintAll("\x07cheat16 detected");
		}
	}

	// Per-frame energy god mode: restore all units to full energy each frame
	if (cheatEnergyActive == 1) {
		ModifyUnitEnergy(All, AllUnits, (all), Anywhere, 100);
	}


	// ── Per-frame supply zeroing (global, outside player loop) ────────────
	// Runs every frame while active. Zeroes supply used for all 8 players,
	// all three races. Addresses confirmed from in-game trigger format:
	//   Zerg   players 1-8: 0x582174..0x582190
	//   Terran players 1-8: 0x582204..0x582220
	//   Protoss players 1-8: 0x582294..0x5822B0
	if (cheatFoodActive == 1) {
		// Zerg
		SetMemory(0x582174, SetTo, 0);
		SetMemory(0x582178, SetTo, 0);
		SetMemory(0x58217C, SetTo, 0);
		SetMemory(0x582180, SetTo, 0);
		SetMemory(0x582184, SetTo, 0);
		SetMemory(0x582188, SetTo, 0);
		SetMemory(0x58218C, SetTo, 0);
		SetMemory(0x582190, SetTo, 0);
		// Terran
		SetMemory(0x582204, SetTo, 0);
		SetMemory(0x582208, SetTo, 0);
		SetMemory(0x58220C, SetTo, 0);
		SetMemory(0x582210, SetTo, 0);
		SetMemory(0x582214, SetTo, 0);
		SetMemory(0x582218, SetTo, 0);
		SetMemory(0x58221C, SetTo, 0);
		SetMemory(0x582220, SetTo, 0);
		// Protoss
		SetMemory(0x582294, SetTo, 0);
		SetMemory(0x582298, SetTo, 0);
		SetMemory(0x58229C, SetTo, 0);
		SetMemory(0x5822A0, SetTo, 0);
		SetMemory(0x5822A4, SetTo, 0);
		SetMemory(0x5822A8, SetTo, 0);
		SetMemory(0x5822AC, SetTo, 0);
		SetMemory(0x5822B0, SetTo, 0);
	}

	setcurpl(cp);
}
