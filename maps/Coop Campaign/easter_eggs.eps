					SetMemory(0x662AC8, Add, 6225920);	// 154: Protoss Nexus
					SetMemory(0x662ACC, Add, 4128768);	// 155: Protoss Robotics Facility
					SetMemory(0x662AD0, Add, 4128768);	// 156: Protoss Pylon
					SetMemory(0x662ADC, Add, 4128768);	// 159: Protoss Observatory
					SetMemory(0x662AE0, Add, 6225920);	// 160: Protoss Gateway
					SetMemory(0x662AE8, Add, 4128768);	// 162: Protoss Photon Cannon
					SetMemory(0x662AEC, Add, 4128768);	// 163: Protoss Citadel of Adun
					SetMemory(0x662AF0, Add, 4128768);	// 164: Protoss Cybernetics Core
					SetMemory(0x662AF4, Add, 4128768);	// 165: Protoss Templar Archives
					SetMemory(0x662AF8, Add, 4128768);	// 166: Protoss Forge
					SetMemory(0x662AFC, Add, 6225920);	// 167: Protoss Stargate
					SetMemory(0x662B04, Add, 4128768);	// 169: Protoss Fleet Beacon
					SetMemory(0x662B08, Add, 4128768);	// 170: Protoss Arbiter Tribunal
					SetMemory(0x662B0C, Add, 4128768);	// 171: Protoss Robotics Support Bay
					SetMemory(0x662B10, Add, 4128768);	// 172: Protoss Shield Battery
				}
				flagCheck = flagCheck - 4096;
			}
			if (flagCheck >= 2048) {
				// ── "speed 1.5 / speed 1.5x" ─────────────────────────────────────────
				dwwrite(0x5124F0, 28);
				eprintAll("\x04Speed set to 1.5x");
				flagCheck = flagCheck - 2048;
			}
			if (flagCheck >= 1024) {
				// ── "speed 1.25 / speed 1.25x" ───────────────────────────────────────
				dwwrite(0x5124F0, 33);
				eprintAll("\x04Speed set to 1.25x");
				flagCheck = flagCheck - 1024;
			}
			if (flagCheck >= 512) {
				// ── "speed normal / speed 1x" ─────────────────────────────────────────
				dwwrite(0x5124F0, 42);
				eprintAll("\x04Speed set to Normal");
				flagCheck = flagCheck - 512;
			}
			if (flagCheck >= 256) {
				// ── "whats mine is mine" ──────────────────────────────────────────────
				foreach(p2 : EUDLoopPlayer("Human")) {
					SetResources(p2, Add, 500, Ore);
				}
				eprintAll("\x04500 Rocks. Congrats I Guess.");
				flagCheck = flagCheck - 256;
			}
			if (flagCheck >= 128) {
				// ── "breathe deep" ────────────────────────────────────────────────────
				foreach(p2 : EUDLoopPlayer("Human")) {
					SetResources(p2, Add, 500, Gas);
				}
				eprintAll("\x04Huffing Vespene Like a Crackhead Overlord.");
				flagCheck = flagCheck - 128;
			}
			if (flagCheck >= 64) {
				// ── "there is no cow level" ───────────────────────────────────────────────────
				eprintAll("\x04Hope you feel good about yourself");
				foreach(p2 : EUDLoopPlayer("Human")) {
					setcurpl(p2);
					Victory();
				}
				flagCheck = flagCheck - 64;
			}
			if (flagCheck >= 32) {
				// ── "game over man" ───────────────────────────────────────────────────
				eprintAll("\x04You Did This To Yourself.");
				foreach(p2 : EUDLoopPlayer("Human")) {
					setcurpl(p2);
					Defeat();
				}
				flagCheck = flagCheck - 32;
			}
			if (flagCheck >= 16) {
				// ── "show me the money" ───────────────────────────────────────────────
				foreach(p2 : EUDLoopPlayer("Human")) {
					SetResources(p2, Add, 10000, OreAndGas);
				}
				eprintAll("\x04You dirty fucking cuck, here you go.");
				flagCheck = flagCheck - 16;
			}
			if (flagCheck >= 8) {
				// ── "the gathering" toggle ────────────────────────────────
				if (cheatEnergyActive == 0) {
					cheatEnergyActive = 1;
					eprintAll("\x04Cheat ENABLED. All Wizards Have Prune Juice.");
				} else {
					cheatEnergyActive = 0;
					eprintAll("\x04Cheat DISABLED. Wizards Have Run Out of Prune Juice.");
				}
				flagCheck = flagCheck - 8;
			}
			if (flagCheck >= 4) {
				// ── "food for thought" toggle ─────────────────────────────
				// Writes max supply for all human players on toggle.
				// BW stores supply doubled: 400 = 200 cap, 1998 = 999 displayed.
				// Adjust 1998 -> 1998 below if you want 1998 displayed.
				if (cheatFoodActive == 0) {
					cheatFoodActive = 1;
					eprintAll("\x04Cheat ENABLED. Supply? Never Heard of It.");
					foreach(p2 : EUDLoopPlayer(None)) {
						dwwrite(0x582144 + p2 * 4, dwread(0x582144 + p2 * 4) + 1998);
						dwwrite(0x5821D4 + p2 * 4, dwread(0x5821D4 + p2 * 4) + 1998);
						dwwrite(0x582264 + p2 * 4, dwread(0x582264 + p2 * 4) + 1998);
					}
				} else {
					cheatFoodActive = 0;
					eprintAll("\x04Cheat DISABLED. Ethiopian Diet is back!");
					foreach(p2 : EUDLoopPlayer(None)) {
						dwwrite(0x582144 + p2 * 4, dwread(0x582144 + p2 * 4) - 1998);
						dwwrite(0x5821D4 + p2 * 4, dwread(0x5821D4 + p2 * 4) - 1998);
						dwwrite(0x582264 + p2 * 4, dwread(0x582264 + p2 * 4) - 1998);
					}
				}
				flagCheck = flagCheck - 4;
			}
			if (flagCheck >= 2) {
				// ── "power overwhelming" toggle ───────────────────────────
				if (cheatGodActive == 0) {
					cheatGodActive = 1;
					eprintAll("\x04Power Overwhelming: ON. Absolute Spineless Worm.");
				} else {
					cheatGodActive = 0;
					eprintAll("\x04Power Overwhelming: OFF. Welcome Back to Mortality.");
				}
				flagCheck = flagCheck - 2;
			}
			// flagCheck should be 0 here if all bits accounted for
		}
	}

	// ── Per-frame: god mode ───────────────────────────────────────────────
	if (cheatGodActive == 1) {
		foreach(player : EUDLoopPlayer("Human")) {
			ModifyUnitHitPoints(All, "(any unit)", player, 64, 100);
		}
	}

	// ── Per-frame: infinite energy ────────────────────────────────────────
	if (cheatEnergyActive == 1) {
		foreach(player : EUDLoopPlayer(None)) {
			ModifyUnitEnergy(All, "(any unit)", player, 64, 100);
		}
	}

	// ── Per-frame: supply max ─────────────────────────────────────────────
	// Overwrites the "200" max supply limit every frame while active, letting it go up to 999 instead
	// BW stores supply doubled: 400 = 200 displayed, 1998 = 999 displayed.
	if (cheatFoodActive == 1) {
		foreach(player : EUDLoopPlayer(None)) {
			dwwrite(0x5821A4 + player * 4, 1998);	// Zerg 
			dwwrite(0x582234 + player * 4, 1998);	// Terran 
			dwwrite(0x5822C4 + player * 4, 1998);	// Protoss 
		}
	}

	setcurpl(cp);
}
