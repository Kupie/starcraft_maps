					SetMemory(0x662B10, Subtract, 4128768);	// 172: Protoss Shield Battery
				} else {
					cheatStackActive = 0;
					eprintAll("\x04Stackshit OFF. Welcome back to walls existing.");
					SetMemory(0x662A08, Add, 6225920);	// 106: Terran Command Center
					SetMemory(0x662A0C, Add, 4128768);	// 107: Terran Comsat Station
					SetMemory(0x662A10, Add, 4128768);	// 108: Terran Nuclear Silo
					SetMemory(0x662A14, Add, 4128768);	// 109: Terran Supply Depot
					SetMemory(0x662A1C, Add, 6225920);	// 111: Terran Barracks
					SetMemory(0x662A20, Add, 4128768);	// 112: Terran Academy
					SetMemory(0x662A24, Add, 6225920);	// 113: Terran Factory
					SetMemory(0x662A28, Add, 6225920);	// 114: Terran Starport
