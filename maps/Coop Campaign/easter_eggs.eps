			if (flagCheck >= 8192) {
					// ── "black sheep wall" vision toggle ──────────────────────────────────
					// Uses +Vi0..+Vi7 / -Vi0..-Vi7 AI scripts to add/remove vision sharing.
					// py_range(8) is compile-time unrolled, so i is a compile-time constant
					// each iteration. GetPlayerInfo(i).type lets us check at compile time
					// which player slots are human (0x06). On DISABLE we skip -ViN for any
					// human-typed slot so we don't clobber human<->human vision that was
					// established by the map's force/alliance setup.
					if (cheatVisionActive == 0) {
						cheatVisionActive = 1;
						eprintAll("\x04Vision cheat ON. Too lazy to spy yourself?");
						// Give all human players vision of every player (0-7).
						// Including other humans is safe — it's additive.
						foreach(p : EUDLoopPlayer("Human")) {
							setcurpl(p);
							foreach(i : py_range(8)) {
								RunAIScript(visionShare[i]);
							}
						}
					} else {
						cheatVisionActive = 0;
						eprintAll("\x04Vision cheat OFF. You'll still feel bad.");
						// Remove vision of non-human players only.
						// GetPlayerInfo(i).type is compile-time: slots typed 0x06 (Human)
						// are silently skipped so human<->human vision is preserved.
						foreach(p : EUDLoopPlayer("Human")) {
							setcurpl(p);
							foreach(i : py_range(8)) {
								if (GetPlayerInfo(i).type != 0x06) {
									RunAIScript(visionShareDisable[i]);
								}
							}
						}
					}
					// Force fast fog of war update after cheat change
					SetMemory(0x0051CE98, SetTo, 1);
					flagCheck = flagCheck - 8192;
				}
			if (flagCheck >= 4096) {
				// ── "stackshit" toggle ────────────────────────────────────────────────
				// Modifies StarEdit Placement Box Height for units.dat to enable/disable
				// building stacking. Enable subtracts to bring values to 1.
				// Disable adds back to restore originals (96 or 64 in high word).
				// Values are packed in the high 16 bits of each dword:
				//   6225920 = 96 << 16 - 1 << 16 = 0x5F0000 (96 -> 1)
				//   4128768 = 64 << 16 - 1 << 16 = 0x3F0000 (64 -> 1)
				if (cheatStackActive == 0) {
					cheatStackActive = 1;
					eprintAll("\x04Stackshit: ON. Build Anywhere, You Degenerate.");
					SetMemory(0x662A08, Subtract, 6225920);	// 106: Terran Command Center
					SetMemory(0x662A0C, Subtract, 4128768);	// 107: Terran Comsat Station
					SetMemory(0x662A10, Subtract, 4128768);	// 108: Terran Nuclear Silo
					SetMemory(0x662A14, Subtract, 4128768);	// 109: Terran Supply Depot
					SetMemory(0x662A1C, Subtract, 6225920);	// 111: Terran Barracks
					SetMemory(0x662A20, Subtract, 4128768);	// 112: Terran Academy
					SetMemory(0x662A24, Subtract, 6225920);	// 113: Terran Factory
					SetMemory(0x662A28, Subtract, 6225920);	// 114: Terran Starport
					SetMemory(0x662A2C, Subtract, 4128768);	// 115: Terran Control Tower
					SetMemory(0x662A30, Subtract, 6225920);	// 116: Terran Science Facility
					SetMemory(0x662A34, Subtract, 4128768);	// 117: Terran Covert Ops
					SetMemory(0x662A38, Subtract, 4128768);	// 118: Terran Physics Lab
					SetMemory(0x662A40, Subtract, 4128768);	// 120: Terran Machine Shop
					SetMemory(0x662A48, Subtract, 6225920);	// 122: Terran Engineering Bay
					SetMemory(0x662A4C, Subtract, 4128768);	// 123: Terran Armory
					SetMemory(0x662A50, Subtract, 4128768);	// 124: Terran Missile Turret
					SetMemory(0x662A54, Subtract, 4128768);	// 125: Terran Bunker
					SetMemory(0x662A68, Subtract, 6225920);	// 130: Infested Command Center
					SetMemory(0x662A6C, Subtract, 6225920);	// 131: Zerg Hatchery
					SetMemory(0x662A70, Subtract, 6225920);	// 132: Zerg Lair
					SetMemory(0x662A74, Subtract, 6225920);	// 133: Zerg Hive
					SetMemory(0x662A78, Subtract, 4128768);	// 134: Zerg Nydus Canal
					SetMemory(0x662A7C, Subtract, 4128768);	// 135: Zerg Hydralisk Den
					SetMemory(0x662A80, Subtract, 4128768);	// 136: Zerg Defiler Mound
